                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="0">
                        <Border x:Name="PART_Track" CornerRadius="3">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>





<Page x:Class="AutoPartsShop.UI.Views.Settings.UserManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="إدارة المستخدمين">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== شريط العنوان والأزرار ===== -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            Command="{Binding ShowAddUserPanelCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="إضافة مستخدم"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource OutlineButton}" Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="تحديث"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="إدارة المستخدمين" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- رسالة الحالة -->
                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="4" Padding="10,4"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#2E7D32"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ===== نموذج الإضافة/التعديل ===== -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12"
                Visibility="{Binding IsAddPanelVisible, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding PanelTitle}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- اسم المستخدم -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="اسم المستخدم" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource InputHeight}"/>
                    </StackPanel>

                    <!-- الاسم الكامل -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="الاسم الكامل" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource InputHeight}"/>
                    </StackPanel>

                    <!-- كلمة المرور -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0">
                        <TextBlock Text="{Binding IsEditing, Converter={StaticResource EditingPasswordLabelConverter}}"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource InputHeight}"/>
                    </StackPanel>

                    <!-- الدور -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,8,0">
                        <TextBlock Text="الدور" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox SelectedValue="{Binding NewRoleId}" SelectedValuePath="Id"
                                  DisplayMemberPath="Name" ItemsSource="{Binding Roles}"
                                  Height="{StaticResource InputHeight}"/>
                    </StackPanel>

                    <!-- حالة التفعيل -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,8,0" VerticalAlignment="Bottom">
                        <CheckBox Content="مستخدم نشط" IsChecked="{Binding IsNewUserActive}"
                                  FontSize="13" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- أزرار الحفظ والإلغاء -->
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,8,0,0"
                                Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource SuccessButton}" Command="{Binding SaveUserCommand}"
                                IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding IsEditing, Converter={StaticResource SaveButtonTextConverter}}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}">
                            <TextBlock Text="إلغاء"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===== جدول المستخدمين ===== -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      BorderThickness="0" Background="Transparent"
                      FontSize="13" GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="{StaticResource AlternateRowBrush}"
                      Padding="8" SelectionMode="Single"
                      CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="الدور" Binding="{Binding RoleName}" Width="120"/>
                    <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy/MM/dd}'}" Width="110"/>
                    <DataGridTextColumn Header="آخر دخول" Binding="{Binding LastLoginAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="140"/>

                    <!-- الحالة -->
                    <DataGridTemplateColumn Header="الحالة" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                            <Setter Property="TextBlock.Foreground" Value="#C62828"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Setter Property="TextBlock.Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="معطل"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="نشط"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- إجراءات -->
                    <DataGridTemplateColumn Header="إجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" ToolTip="تعديل"
                                            Command="{Binding DataContext.ShowEditUserPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="تبديل الحالة"
                                            Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="حذف"
                                            Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>

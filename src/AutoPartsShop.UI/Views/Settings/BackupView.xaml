<Page x:Class="AutoPartsShop.UI.Views.Settings.BackupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      Title="النسخ الاحتياطي"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- ============ إعدادات النسخ الاحتياطي التلقائي ============ -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="النسخ الاحتياطي التلقائي" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                    <!-- تفعيل النسخ التلقائي -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="تفعيل النسخ الاحتياطي التلقائي:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding IsAutoBackupEnabled}"
                                  VerticalAlignment="Center"
                                  Content="مُفعّل"/>
                    </Grid>

                    <!-- نوع الجدولة -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نوع الجدولة:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{Binding ScheduleTypeIndex}"
                                  Padding="8,6" FontSize="13" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem Content="كل فترة (دقائق/ساعات/أيام)"/>
                            <ComboBoxItem Content="يومياً في وقت محدد"/>
                            <ComboBoxItem Content="أسبوعياً في يوم محدد"/>
                            <ComboBoxItem Content="شهرياً في يوم محدد"/>
                        </ComboBox>
                    </Grid>

                    <!-- ===== وضع: كل فترة (Interval) ===== -->
                    <Grid Margin="0,0,0,16"
                          Visibility="{Binding IsIntervalMode, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="كل:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding IntervalValue, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Width="100"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding IntervalUnits}"
                                  SelectedIndex="{Binding IntervalUnitIndex}"
                                  Padding="8,6" FontSize="13" Width="120" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="3"
                                   Text="أقل فترة: 5 دقائق"
                                   Foreground="#94A3B8" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: يومي (Daily) — وقت فقط ===== -->
                    <Grid Margin="0,0,0,16"
                          Visibility="{Binding IsDailyMode, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الساعة:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Hours}"
                                  SelectedItem="{Binding SelectedHour}"
                                  Padding="8,6" FontSize="13" Width="80"/>
                        <TextBlock Grid.Column="2" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding Minutes}"
                                  SelectedItem="{Binding SelectedMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                        <TextBlock Grid.Column="4"
                                   Text="يتم النسخ كل يوم في هذه الساعة"
                                   Foreground="#94A3B8" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: أسبوعي (Weekly) — يوم + وقت ===== -->
                    <Grid Margin="0,0,0,16"
                          Visibility="{Binding IsWeeklyMode, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="يوم:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding DaysOfWeek}"
                                  SelectedIndex="{Binding SelectedDayOfWeekIndex}"
                                  Padding="8,6" FontSize="13" Width="120"/>
                        <TextBlock Grid.Column="2" Text="الساعة:"
                                   VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,0,0"/>
                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding Hours}"
                                  SelectedItem="{Binding SelectedHour}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="4" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="5"
                                  ItemsSource="{Binding Minutes}"
                                  SelectedItem="{Binding SelectedMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: شهري (Monthly) — يوم من الشهر + وقت ===== -->
                    <Grid Margin="0,0,0,16"
                          Visibility="{Binding IsMonthlyMode, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="يوم:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding DaysOfMonth}"
                                  SelectedItem="{Binding SelectedDayOfMonth}"
                                  Padding="8,6" FontSize="13" Width="80"/>
                        <TextBlock Grid.Column="2" Text="من كل شهر"
                                   VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="الساعة:"
                                   VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,0,0"/>
                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding Hours}"
                                  SelectedItem="{Binding SelectedHour}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="5" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="6"
                                  ItemsSource="{Binding Minutes}"
                                  SelectedItem="{Binding SelectedMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- ===== معاينة الموعد التالي ===== -->
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#3B82F6"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="النسخة القادمة:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding NextBackupDisplay}"
                                       VerticalAlignment="Center" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>

                    <!-- ===== مسار النسخ الاحتياطي ===== -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="مسار النسخ الاحتياطي:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding BackupDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" IsReadOnly="True"/>
                        <Button Grid.Column="2"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding BrowseBackupDirectoryCommand}"
                                Content="استعراض..."
                                Margin="8,0,0,0"/>
                    </Grid>

                    <!-- ===== زر الحفظ ===== -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveBackupSettingsCommand}"
                            HorizontalAlignment="Left"
                            Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="حفظ إعدادات النسخ الاحتياطي"/>
                        </StackPanel>
                    </Button>

                    <!-- ===== رسالة الحالة ===== -->
                    <Border Background="#F0FDF4" BorderBrush="#16A34A" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#15803D" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============ نسخ احتياطي يدوي ============ -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="نسخ احتياطي يدوي" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateBackupCommand}"
                                Margin="0,0,8,0"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="بدء النسخ الاحتياطي الآن"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding RestoreBackupCommand}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="استعادة نسخة"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ============ سجل النسخ الاحتياطي ============ -->
            <Border Style="{StaticResource CardStyle}" Padding="24">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="سجل النسخ الاحتياطي" FontSize="18" FontWeight="SemiBold"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding RefreshCommand}"
                                Content="&#xE72C; تحديث"
                                Padding="12,6"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding BackupHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="1"
                              BorderBrush="#E2E8F0"
                              RowHeight="36"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="التاريخ والوقت"
                                                Binding="{Binding BackupDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                Width="*"/>
                            <DataGridTextColumn Header="حجم الملف (MB)"
                                                Binding="{Binding FileSizeMB, StringFormat='{}{0:N2}'}"
                                                Width="120"/>
                            <DataGridTextColumn Header="الحالة"
                                                Binding="{Binding Status}"
                                                Width="100"/>
                            <DataGridTextColumn Header="ملاحظات"
                                                Binding="{Binding Notes}"
                                                Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state (hidden by default; show only when there are no backups) -->
                    <TextBlock Text="لا توجد نسخ احتياطية بعد"
                               Foreground="#94A3B8" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,20"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

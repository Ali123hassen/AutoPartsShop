<Page x:Class="AutoPartsShop.UI.Views.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      Title="الإعدادات" FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <converters:StringToImageSourceConverter x:Key="StringToImage"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <!-- System Settings Card -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إعدادات النظام" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="اسم المحل:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Style="{StaticResource {x:Type TextBox}}"/>
                    </Grid>

                    <!-- شعار المحل -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="شعار المحل:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <StackPanel Grid.Column="1">
                            <!-- معاينة اللوقو -->
                            <Border Width="80" Height="80" CornerRadius="8" Background="#F5F5F5"
                                    BorderBrush="#E0E0E0" BorderThickness="1"
                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                <Grid>
                                    <!-- صورة اللوقو -->
                                    <Image Source="{Binding ShopLogoPath, Converter={StaticResource StringToImage}}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FlowDirection="LeftToRight"
                                           Visibility="{Binding HasShopLogo, Converter={StaticResource BoolToVisConverter}}"/>
                                    <!-- أيقونة افتراضية إذا لم يكن هناك لوقو -->
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                               Foreground="#BDBDBD" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasShopLogo, Converter={StaticResource InvertBoolToVisConverter}}"/>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding BrowseShopLogoCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="اختر صورة"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RemoveShopLogoCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,6"
                                        Visibility="{Binding HasShopLogo, Converter={StaticResource BoolToVisConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="إزالة اللوقو" Foreground="#EF4444"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="العنوان:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding ShopAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الهاتف:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding ShopPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" FlowDirection="LeftToRight"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نسبة الضريبة %:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Width="120" HorizontalAlignment="Left" FlowDirection="LeftToRight"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نسبة الربح %:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding ProfitMargin, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Width="120" HorizontalAlignment="Left" FlowDirection="LeftToRight"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="العملة:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding Currency}" SelectedValuePath="Tag"
                                  IsEditable="False" Padding="8,6" FontSize="13" Width="250" HorizontalAlignment="Left">
                            <ComboBoxItem Content="ر.س - ريال سعودي" Tag="ر.س"/>
                            <ComboBoxItem Content="ر.ي - ريال يمني" Tag="ر.ي"/>
                            <ComboBoxItem Content="د.إ - درهم إماراتي" Tag="د.إ"/>
                            <ComboBoxItem Content="د.ك - دينار كويتي" Tag="د.ك"/>
                            <ComboBoxItem Content="ر.ع - ريال عماني" Tag="ر.ع"/>
                            <ComboBoxItem Content="ر.ق - ريال قطري" Tag="ر.ق"/>
                            <ComboBoxItem Content="د.ب - دينار بحريني" Tag="د.ب"/>
                        </ComboBox>
                    </Grid>

                    <Button Command="{Binding SaveUserSettingsCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="حفظ الإعدادات"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Application Settings Card -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إعدادات التطبيق" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="تشغيل الإشعارات:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding NotificationsEnabled}" VerticalAlignment="Center" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="تنبيه المخزون المنخفض:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding LowStockAlertEnabled}" VerticalAlignment="Center" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="حد المخزون المنخفض:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding LowStockThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Width="100" HorizontalAlignment="Left" FlowDirection="LeftToRight"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SaveAppSettingsCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="تطبيق الإعدادات"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ResetSettingsCommand}"
                                Style="{StaticResource SecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="إعادة تعيين الإعدادات"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ============================================ -->
            <!-- License Info Card                            -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="#9C27B0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="معلومات الترخيص" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- License Status -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="حالة الترخيص:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Padding="10,5" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLicenseTrial}" Value="True">
                                                <Setter Property="Background" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasActiveLicense}" Value="False">
                                                <Setter Property="Background" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding LicenseStatusText}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <Border Padding="8,4" CornerRadius="4" Background="#FFF3E0" Margin="8,0,0,0"
                                    Visibility="{Binding IsLicenseExpiringSoon, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="ينتهي قريباً!" Foreground="#E65100" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Customer Name -->
                    <Grid Margin="0,0,0,14" Visibility="{Binding HasActiveLicense, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="اسم العميل:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding LicenseCustomerName}" FontSize="13" Foreground="#333"/>
                    </Grid>

                    <!-- License Type -->
                    <Grid Margin="0,0,0,14" Visibility="{Binding HasActiveLicense, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نوع الترخيص:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding LicenseTypeText}" FontSize="13" Foreground="#333"/>
                    </Grid>

                    <!-- Expiration Date -->
                    <Grid Margin="0,0,0,14" Visibility="{Binding HasActiveLicense, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="تاريخ الانتهاء:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding LicenseExpirationDate}" FontSize="13" Foreground="#333"/>
                    </Grid>

                    <!-- Days Remaining -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الأيام المتبقية:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding LicenseDaysRemaining}" FontSize="14" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLicenseExpiringSoon}" Value="True">
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasActiveLicense}" Value="False">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Hardware ID -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="بصمة الجهاز:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding LicenseHardwareId, Mode=OneWay}" IsReadOnly="True"
                                 FontSize="11" FontFamily="Consolas" Padding="8,6"
                                 Background="#F5F5F5" FlowDirection="LeftToRight" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Command="{Binding CopyHardwareIdCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="8,6" Margin="8,0,0,0"
                                AutomationProperties.Name="نسخ البصمة">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                    </Grid>

                    <!-- License Actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ShowLicenseActivationCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="تفعيل / تجديد الترخيص"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Backup Settings Card -->
            <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="النسخ الاحتياطي" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- تفعيل النسخ التلقائي -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نسخ احتياطي تلقائي:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoBackupEnabled}" VerticalAlignment="Center" FontSize="13"
                                  Content="مُفعّل"/>
                    </Grid>

                    <!-- نوع الجدولة -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="نوع الجدولة:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding AutoBackupScheduleTypeIndex}"
                                  Padding="8,6" FontSize="13" Width="280" HorizontalAlignment="Left">
                            <ComboBoxItem Content="كل فترة (دقائق/ساعات/أيام)"/>
                            <ComboBoxItem Content="يومياً في وقت محدد"/>
                            <ComboBoxItem Content="أسبوعياً في يوم محدد"/>
                            <ComboBoxItem Content="شهرياً في يوم محدد"/>
                        </ComboBox>
                    </Grid>

                    <!-- ===== وضع: كل فترة (Interval) ===== -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsIntervalMode, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="كل:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding AutoBackupIntervalValue, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Width="100" FlowDirection="LeftToRight"/>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding IntervalUnits}"
                                  SelectedIndex="{Binding AutoBackupIntervalUnitIndex}"
                                  Padding="8,6" FontSize="13" Width="120" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="أقل فترة: 5 دقائق"
                                   Foreground="#94A3B8" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: يومي (Daily) — وقت فقط ===== -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsDailyMode, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الساعة:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding HoursList}"
                                  SelectedItem="{Binding AutoBackupHour}"
                                  Padding="8,6" FontSize="13" Width="80"/>
                        <TextBlock Grid.Column="2" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding MinutesList}"
                                  SelectedItem="{Binding AutoBackupMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="يتم النسخ كل يوم في هذه الساعة"
                                   Foreground="#94A3B8" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: أسبوعي (Weekly) — يوم + وقت ===== -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsWeeklyMode, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="يوم:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding DaysOfWeekList}"
                                  SelectedIndex="{Binding AutoBackupDayOfWeekIndex}"
                                  Padding="8,6" FontSize="13" Width="120"/>
                        <TextBlock Grid.Column="2" Text="الساعة:"
                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" Margin="16,0,0,0"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding HoursList}"
                                  SelectedItem="{Binding AutoBackupHour}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="4" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="5" ItemsSource="{Binding MinutesList}"
                                  SelectedItem="{Binding AutoBackupMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- ===== وضع: شهري (Monthly) — يوم من الشهر + وقت ===== -->
                    <Grid Margin="0,0,0,14"
                          Visibility="{Binding IsMonthlyMode, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="يوم:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding DaysOfMonthList}"
                                  SelectedItem="{Binding AutoBackupDayOfMonth}"
                                  Padding="8,6" FontSize="13" Width="80"/>
                        <TextBlock Grid.Column="2" Text="من كل شهر"
                                   VerticalAlignment="Center" FontSize="13" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="الساعة:"
                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" Margin="16,0,0,0"/>
                        <ComboBox Grid.Column="4" ItemsSource="{Binding HoursList}"
                                  SelectedItem="{Binding AutoBackupHour}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="5" Text=":" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <ComboBox Grid.Column="6" ItemsSource="{Binding MinutesList}"
                                  SelectedItem="{Binding AutoBackupMinute}"
                                  Padding="8,6" FontSize="13" Width="80" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- ===== معاينة الموعد التالي ===== -->
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#3B82F6"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="النسخة القادمة:" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding NextBackupDisplay}" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>

                    <!-- مسار النسخ الاحتياطي -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="مجلد النسخ الاحتياطي:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        <TextBox Grid.Column="1" Text="{Binding BackupDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" IsReadOnly="True" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" Command="{Binding BrowseBackupDirectoryCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="8,6"
                                AutomationProperties.Name="استعراض مجلد النسخ الاحتياطي">
                            <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsCreatingBackup, Converter={StaticResource InvertBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="إنشاء نسخة احتياطية"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RestoreBackupCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsRestoring, Converter={StaticResource InvertBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="استعادة نسخة"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveAppSettingsCommand}"
                                Style="{StaticResource SuccessButton}"
                                IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="حفظ إعدادات النسخ"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <Border Padding="16,10" CornerRadius="8" MinWidth="300"
                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>

            <!-- ===== Danger Zone: Database Reset ===== -->
            <Border Background="#FEF2F2" BorderBrush="#DC2626" BorderThickness="2"
                    CornerRadius="8" Padding="24" Margin="0,20,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="#DC2626" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="منطقة الخطر" FontSize="18" FontWeight="Bold"
                                   Foreground="#DC2626" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="إعادة ضبط قاعدة البيانات" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,6" Foreground="#7F1D1D"/>
                    <TextBlock Text="سيتم مسح جميع الفواتير والمرتجعات والمخزون وقطع الغيار نهائياً. "
                                FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4" Foreground="#7F1D1D"/>
                    <TextBlock Text="يتم الاحتفاظ بـ: المستخدمون، الأدوار، الصلاحيات، الإعدادات، الفئات، سجلات التدقيق."
                                FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" Foreground="#7F1D1D"/>

                    <Button Command="{Binding ResetDatabaseCommand}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            FontSize="13"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#B91C1C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B91C1C"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#991B1B"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#FCA5A5"/>
                                        <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="إعادة ضبط قاعدة البيانات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
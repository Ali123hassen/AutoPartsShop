<Window x:Class="AutoPartsShop.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoPartsShop.UI.ViewModels"
        xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
        Title="نظام محاسبي"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
        <converters:StringToImageSourceConverter x:Key="StringToImage"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Row="0" Margin="0,24,0,16">
                    <!-- اللوقو أو النص الافتراضي -->
                    <Grid Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <!-- صورة اللوقو -->
                        <Border CornerRadius="25" ClipToBounds="True">
                            <Image Source="{Binding ShopLogoPath, Converter={StaticResource StringToImage}}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FlowDirection="LeftToRight"
                                   Visibility="{Binding HasShopLogo, Converter={StaticResource BoolToVisibility}}"/>
                        </Border>
                        <!-- نص AP الافتراضي -->
                        <Border CornerRadius="25" Background="#2C6E97"
                                Visibility="{Binding HasShopLogo, Converter={StaticResource InvertBoolToVis}}">
                            <TextBlock Text="AP" FontSize="20" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding ShopName}"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="النظام المحاسبي"
                               Foreground="#8BBBD9" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="0,8">
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToDashboardCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="لوحة التحكم" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToSparePartsCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="قطع الغيار" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToPOSCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="نقطة البيع" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToPurchaseInvoiceCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="فاتورة المشتريات" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToInvoicesCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="الفواتير" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToReturnsCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="المرتجعات" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToInventoryCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8DE;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="المخزون" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToReportsCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="التقارير" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="#2C6E97" Margin="16,12"/>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToSettingsCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="الإعدادات" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToUserManagementCommand}"
                                Margin="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="المستخدمين" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- User Info -->
                <Border Grid.Row="2" Background="#0E3A5C" Padding="16,12" CornerRadius="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding CurrentUser.FullName}"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentUser.RoleName}"
                                       Foreground="#8BBBD9" FontSize="10"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Command="{Binding LogoutCommand}"
                                Foreground="#EC7063"
                                ToolTip="تسجيل الخروج"
                                Margin="4,0,0,0">
                            <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" Padding="24,12"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentPageTitle}"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Notification Bell with Badge -->
                        <Grid Margin="0,0,12,0">
                            <Button Style="{StaticResource IconButton}" 
                                    Command="{Binding ToggleNotificationPanelCommand}"
                                    ToolTip="الإشعارات"
                                    x:Name="NotificationBellButton">
                                <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                            <!-- Badge -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Margin="0,-4,0,0"
                                    Background="#EF4444" CornerRadius="8" 
                                    Padding="4,1"
                                    Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding UnreadNotificationCount}" 
                                           Foreground="White" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           MinWidth="12" TextAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="{Binding CurrentUser.FullName[0]}"
                                       Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Frame -->
            <Grid Grid.Row="1">
                <Frame x:Name="MainFrame"
                       Style="{StaticResource ContentFrameStyle}"
                       NavigationUIVisibility="Hidden"
                       Margin="16"/>

                <!-- Notification Panel (Overlay) -->
                <Border x:Name="NotificationPanel"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="16,0,0,0"
                        Width="380" MaxHeight="500"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="0"
                        Visibility="{Binding IsNotificationPanelOpen, Converter={StaticResource BoolToVisibility}}"
                        Panel.ZIndex="100">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="15" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Header -->
                        <Border Background="#F8FAFC" CornerRadius="8,8,0,0" Padding="16,12"
                                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="الإشعارات" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <Button Grid.Column="1" Command="{Binding MarkNotificationsReadCommand}"
                                        FontSize="11" Foreground="#3B82F6" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0" Padding="4,0">
                                    تعيين الكل كمقروء
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Notifications List -->
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Notifications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="16,10" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Type Icon -->
                                                    <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                                <Setter Property="Text" Value="&#xE946;"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                                        <Setter Property="Text" Value="&#xE7BA;"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Error">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                        <Setter Property="Text" Value="&#xE783;"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Success">
                                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                                        <Setter Property="Text" Value="&#xE73E;"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Message}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}" FontSize="10" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty State -->
                        <StackPanel Margin="0,30" HorizontalAlignment="Center"
                                    Visibility="{Binding HasUnreadNotifications, Converter={StaticResource InvertBoolToVis}}">
                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="لا توجد إشعارات جديدة" FontSize="13" Foreground="#94A3B8" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Toast Notification -->
        <Border x:Name="ToastBorder"
                Grid.Column="1"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0"
                Padding="20,12"
                CornerRadius="8"
                MinWidth="350" MaxWidth="500"
                Visibility="Collapsed"
                Panel.ZIndex="200">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="15" Opacity="0.2" Direction="270"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Tag, ElementName=ToastBorder}" Value="Warning">
                            <Setter Property="Background" Value="#92400E"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Tag, ElementName=ToastBorder}" Value="Error">
                            <Setter Property="Background" Value="#991B1B"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Tag, ElementName=ToastBorder}" Value="Success">
                            <Setter Property="Background" Value="#065F46"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastTitle" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text=" — " Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastMessage" Foreground="#D1D5DB" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

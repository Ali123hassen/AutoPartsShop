<Page x:Class="AutoPartsShop.UI.Views.POS.POSView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      Title="نقطة البيع" FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================ -->
        <!-- LEFT PANEL: Product Search & List            -->
        <!-- ============================================ -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="نقطة البيع" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="ابحث بالاسم أو رقم القطعة أو الباركود" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Search / Barcode Bar -->
                <Border Grid.Row="1" Style="{StaticResource InputGroupStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="SearchTextBox" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="8,6"
                                 FontSize="14">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding BarcodeSearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" Command="{Binding BarcodeSearchCommand}" 
                                Style="{StaticResource PrimaryButton}" Height="30" FontSize="11" Padding="8,0" Margin="4,2,4,2" ToolTip="بحث بالباركود"
                                AutomationProperties.Name="بحث بالباركود">
                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Products DataGrid -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding SearchResults}" AutoGenerateColumns="False"
                          IsReadOnly="True" BorderThickness="0" Background="Transparent"
                          FontSize="13" GridLinesVisibility="Horizontal"
                          SelectedItem="{Binding SelectedProduct}"
                          Cursor="Hand"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <!-- نمط موحد للخلايا: يلتف النص للسطر التالي بدلاً من القص -->
                        <Style x:Key="CellWrapStyle" TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="TextTrimming" Value="None"/>
                        </Style>
                        <Style x:Key="CellNoWrapStyle" TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="NoWrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding AddToCartCommand}" 
                                      CommandParameter="{Binding SelectedProduct}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم القطعة" Binding="{Binding PartNumber}" Width="Auto" MinWidth="80"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTextColumn Header="الباركود" Binding="{Binding Barcode}" Width="Auto" MinWidth="80"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding Name}" Width="*" MinWidth="200"
                                           ElementStyle="{StaticResource CellWrapStyle}"/>
                        <DataGridTextColumn Header="السيارة" Binding="{Binding CompatibleCar}" Width="Auto" MinWidth="100" MaxWidth="220"
                                           ElementStyle="{StaticResource CellWrapStyle}"/>
                        <DataGridTextColumn Header="الموديل" Binding="{Binding CarModel}" Width="Auto" MinWidth="100" MaxWidth="220"
                                           ElementStyle="{StaticResource CellWrapStyle}"/>
                        <DataGridTextColumn Header="الموقع" Binding="{Binding Location}" Width="Auto" MinWidth="70"
                                           ElementStyle="{StaticResource CellWrapStyle}"/>
                        <DataGridTextColumn Header="سعر التكلفة" Binding="{Binding PurchasePrice, StringFormat='{}{0:N2}'}" Width="Auto" MinWidth="80"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTextColumn Header="سعر البيع" Binding="{Binding SalePrice, StringFormat='{}{0:N2}'}" Width="Auto" MinWidth="80"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinSalePrice, StringFormat='{}{0:N2}'}" Width="Auto" MinWidth="80"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTextColumn Header="المخزون" Binding="{Binding CurrentStock}" Width="Auto" MinWidth="60"
                                           ElementStyle="{StaticResource CellNoWrapStyle}"/>
                        <DataGridTemplateColumn Header="إضافة" Width="Auto" MinWidth="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SuccessButton}" Height="28" FontSize="11" Padding="6,0"
                                            Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="إضافة للسلة">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- RIGHT PANEL: Cart / Invoice                  -->
        <!-- ============================================ -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Customer info -->
                    <RowDefinition Height="*"/>
                    <!-- Cart items -->
                    <RowDefinition Height="Auto"/>
                    <!-- Totals -->
                    <RowDefinition Height="Auto"/>
                    <!-- Payment method -->
                    <RowDefinition Height="Auto"/>
                    <!-- Paid amount (cash only) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- Cart Header -->
                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="16,12" CornerRadius="6,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="الفاتورة الحالية" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <Border Grid.Column="1" Background="#FFFFFF30" CornerRadius="12" Padding="8,2">
                            <TextBlock Text="{Binding CartItemCount, StringFormat='{}{0} عنصر'}" 
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Customer Name -->
                <Border Grid.Row="1" Padding="16,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" 
                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" Padding="0" Height="28"
                                 FontSize="13" FlowDirection="RightToLeft"/>
                    </Grid>
                </Border>

                <!-- Cart Items List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding CartItems}" BorderThickness="0" Background="Transparent"
                         SelectedItem="{Binding SelectedCartItem}" MaxHeight="350"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0: Item Name & Remove Button -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding PartName}" FontWeight="SemiBold" FontSize="12"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PartName}"/>
                                        <TextBlock Text="{Binding Location, StringFormat=' ({0})'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasLocation, Converter={StaticResource BoolToVisConverter}}"/>
                                    </StackPanel>
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" Style="{StaticResource IconButton}" ToolTip="حذف" Padding="4"
                                            AutomationProperties.Name="حذف">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource DangerBrush}"/>
                                    </Button>

                                    <!-- Row 1: Car Compatibility Badges (WrapPanel - يلتف للسطر التالي إذا زاد العرض) -->
                                    <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0" Orientation="Horizontal"
                                               Visibility="{Binding HasCarInfo, Converter={StaticResource BoolToVisConverter}}">
                                        <Border Background="#E8F4F8" CornerRadius="3" Padding="6,2" Margin="0,0,4,2"
                                                BorderBrush="#D5DBDB" BorderThickness="1"
                                                Visibility="{Binding HasCompatibleCar, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🚗" FontSize="10" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CompatibleCar}" FontSize="10" Foreground="#1A5276" VerticalAlignment="Center" FontWeight="Medium"
                                                           TextWrapping="Wrap" MaxWidth="200" ToolTip="{Binding CompatibleCar}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FEF9E7" CornerRadius="3" Padding="6,2" Margin="0,0,4,2"
                                                BorderBrush="#F1C40F" BorderThickness="1"
                                                Visibility="{Binding HasCarModel, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔧" FontSize="10" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CarModel}" FontSize="10" Foreground="#7D6608" VerticalAlignment="Center" FontWeight="Medium"
                                                           TextWrapping="Wrap" MaxWidth="200" ToolTip="{Binding CarModel}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F4ECF7" CornerRadius="3" Padding="6,2" Margin="0,0,4,2"
                                                BorderBrush="#D2B4DE" BorderThickness="1" MaxWidth="100"
                                                Visibility="{Binding HasCarYear, Converter={StaticResource BoolToVisConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅" FontSize="10" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CarYear}" FontSize="10" Foreground="#5B2C6F" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <!-- Row 2: Quantity & Price Controls -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Command="{Binding DataContext.DecrementQuantityCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" Style="{StaticResource IconButton}" Padding="4,2" Margin="0,0,2,0"
                                                AutomationProperties.Name="تقليل الكمية">
                                            <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Button>
                                        <Border Background="#F0F4F8" CornerRadius="4" Padding="8,2" Margin="2,0">
                                            <TextBlock Text="{Binding Quantity}" FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" MinWidth="20" TextAlignment="Center"/>
                                        </Border>
                                        <Button Command="{Binding DataContext.IncrementQuantityCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" Style="{StaticResource IconButton}" Padding="4,2" Margin="2,0,8,0"
                                                AutomationProperties.Name="زيادة الكمية">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Button>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                            <Run Text="{Binding Quantity, Mode=OneWay}"/>
                                            <Run Text=" x "/>
                                            <Run Text="{Binding UnitPrice, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Line Total -->
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LineTotal, StringFormat='{}{0:N2}'}"
                                               FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,4,0,0"/>

                                    <!-- Row 3: Discount Per Item -->
                                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="خصم:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding DiscountAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" Height="22" FontSize="11" Padding="3,1"
                                                 HorizontalContentAlignment="Center" FlowDirection="LeftToRight"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrencySymbol}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Totals Section -->
                <Border Grid.Row="3" Padding="16,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="المجموع الفرعي:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubTotalDisplay}" FontSize="12" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding TaxLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TaxAmountDisplay}" FontSize="12" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="الخصم الكلي:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalDiscountDisplay}" 
                                   FontSize="12" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>

                        <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,2,0,6"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="الإجمالي:" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TotalAmountDisplay}" 
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Payment Method -->
                <Border Grid.Row="4" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding SetCashPaymentCommand}" Margin="0,0,4,0" Height="36"
                                FontWeight="SemiBold" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                    <Setter Property="Background" Value="#E9ECEF"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCashPayment}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="نقدي"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Command="{Binding SetCardPaymentCommand}" Margin="4,0,0,0" Height="36"
                                FontWeight="SemiBold" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                    <Setter Property="Background" Value="#E9ECEF"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCashPayment}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="بطاقة"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Paid Amount & Change (Cash only) -->
                <Border Grid.Row="5" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Visibility="{Binding IsCashPayment, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="المبلغ المدفوع:" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="120" Height="28" FontSize="12" FlowDirection="LeftToRight" 
                                 HorizontalContentAlignment="Center" Padding="4,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="الباقي:" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ChangeAmountDisplay}" 
                                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <Border Grid.Row="6" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- Print / View Invoice Buttons (shown after successful sale) -->
                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding CanPrintLastInvoice, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding PrintLastInvoiceCommand}"
                                    Height="38" FontSize="12" Margin="0,0,4,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="طباعة الفاتورة"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Command="{Binding ViewLastInvoiceCommand}"
                                    Height="38" FontSize="12" Margin="4,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                        <Setter Property="Background" Value="#E0E7FF"/>
                                        <Setter Property="Foreground" Value="#1E3A5F"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="عرض الفاتورة"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Main Action Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding CompleteSaleCommand}" 
                                    Style="{StaticResource SuccessButton}" Height="44" FontSize="14" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                                    <TextBlock Text="إصدار الفاتورة"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource DangerButton}" Height="44" FontSize="13" MinWidth="80">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="إلغاء"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Status Message Overlay -->
        <Border Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80"
                Padding="16,10" CornerRadius="8" MinWidth="300"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
    </Grid>
</Page>

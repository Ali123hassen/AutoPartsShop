<Window x:Class="AutoPartsShop.UI.Views.SpareParts.SparePartEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoPartsShop.UI.ViewModels"
        xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
        Title="إضافة صنف"
        Height="600" Width="600"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullableNumericConverter x:Key="NullableNumeric"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource PageTitleStyle}">
                    <Setter Property="Text" Value="إضافة صنف جديد"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="تعديل الصنف"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Error Message -->
                <Border Background="#FDEDEC" CornerRadius="4" Padding="12,8" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12"/>
                </Border>

                <!-- البيانات الأساسية -->
                <Border Background="#F0F4F8" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                    <TextBlock Text="البيانات الأساسية" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="رقم القطعة *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding PartNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الباركود" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="اسم القطعة *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الاسم بالعربية" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding NameAr, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="التصنيف" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedItem="{Binding SelectedCategory}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الوحدة" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الشركة المصنعة" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="موقع القطعة" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- سعر البيع - يظهر فقط في وضع التعديل -->
                <Grid Margin="0,0,0,12" Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="سعر البيع" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding SalePrice, StringFormat=N2, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الحد الأدنى للمخزون" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding MinStockLevel, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=False, ValidatesOnDataErrors=False}"/>
                    </StackPanel>
                </Grid>

                <!-- توافق السيارة -->
                <Border Background="#F0F4F8" CornerRadius="4" Padding="8,4" Margin="0,8,0,8">
                    <TextBlock Text="توافق السيارة" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                </Border>

                <!-- السيارات المتوافقة (متعددة) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- قائمة السيارات -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="السيارات المتوافقة" Style="{StaticResource FormLabelStyle}"/>

                        <!-- إدخال سيارة جديدة -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewCompatibleCar, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="CompatibleCarInput_KeyDown"/>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Width="32" Height="32" Margin="4,0,0,0"
                                    FontSize="18" FontWeight="Bold"
                                    Command="{Binding AddCompatibleCarCommand}"
                                    ToolTip="إضافة سيارة"/>
                        </Grid>

                        <!-- قائمة السيارات المضافة -->
                        <Border BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="4" Height="80" Padding="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CompatibleCars}" Padding="2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#E8F4F8" CornerRadius="3" Padding="6,3" Margin="2"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="12"/>
                                                    <Button Content="✕" Margin="6,0,0,0" Padding="4,0"
                                                            FontSize="10" Foreground="#C0392B"
                                                            Background="Transparent" BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveCompatibleCarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Text="مثال: Toyota, Nissan, Honda" FontSize="10" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- قائمة الموديلات -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="موديلات السيارات" Style="{StaticResource FormLabelStyle}"/>

                        <!-- إدخال موديل جديد -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewCarModel, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="CarModelInput_KeyDown"/>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Width="32" Height="32" Margin="4,0,0,0"
                                    FontSize="18" FontWeight="Bold"
                                    Command="{Binding AddCarModelCommand}"
                                    ToolTip="إضافة موديل"/>
                        </Grid>

                        <!-- قائمة الموديلات المضافة -->
                        <Border BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="4" Height="80" Padding="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CarModels}" Padding="2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FEF9E7" CornerRadius="3" Padding="6,3" Margin="2"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="12"/>
                                                    <Button Content="✕" Margin="6,0,0,0" Padding="4,0"
                                                            FontSize="10" Foreground="#C0392B"
                                                            Background="Transparent" BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveCarModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Text="مثال: Camry, Corolla, Sunny" FontSize="10" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="سنة الصنع" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding CarYear, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="بلد المنشأ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding CountryOfOrigin, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- بيانات إضافية -->
                <Border Background="#F0F4F8" CornerRadius="4" Padding="8,4" Margin="0,8,0,8">
                    <TextBlock Text="بيانات إضافية" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الوزن (كجم)" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Weight, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=False, ValidatesOnDataErrors=False}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="نوع الباركود" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox Text="{Binding BarcodeType, UpdateSourceTrigger=PropertyChanged}" IsEditable="True">
                            <ComboBoxItem Content="EAN-13"/>
                            <ComboBoxItem Content="Code128"/>
                            <ComboBoxItem Content="QR Code"/>
                            <ComboBoxItem Content="Code39"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="ملاحظات" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,12"/>

                <CheckBox Content="نشط" IsChecked="{Binding IsActive}" Margin="0,0,0,12"/>

                <!-- تنبيه عند الإضافة فقط -->
                <Border Background="#FFF3CD" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#856404" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="لإضافة أسعار وكميات، استخدم صفحة فاتورة المشتريات" Foreground="#856404" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                    Content="حفظ"
                    Command="{Binding SaveCommand}"
                    MinWidth="120" Margin="0,0,12,0"/>

            <Button Grid.Column="2" Style="{StaticResource OutlineButton}"
                    Content="إلغاء"
                    Command="{Binding CancelCommand}"
                    MinWidth="100"/>
        </Grid>
    </Grid>
</Window>

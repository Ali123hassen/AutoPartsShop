<Page x:Class="AutoPartsShop.UI.Views.PurchaseInvoices.PurchaseInvoiceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AutoPartsShop.UI.ViewModels"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToStringConverter x:Key="DecimalToString"/>
        <converters:NullableNumericConverter x:Key="NullableNumeric"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <!-- PURCHASE CART (Top) -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                    <TextBlock Text="فاتورة مشتريات جديدة" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

                    <!-- Search -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="بحث بالاسم أو رقم القطعة أو الباركود" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="باركود"
                                Command="{Binding BarcodeSearchCommand}" MinWidth="70" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Search Results -->
                    <ListBox ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedProduct}"
                             Height="100" Margin="0,0,0,8" DisplayMemberPath="Name"
                             MouseDoubleClick="SearchResults_MouseDoubleClick"/>

                    <!-- Cart Items -->
                    <TextBlock Text="الأصناف المضافة:" FontWeight="SemiBold" FontSize="13" Foreground="#2C3E50" Margin="0,4,0,4"/>
                    <DataGrid ItemsSource="{Binding CartItems}" SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False" MaxHeight="300"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="القطعة" Binding="{Binding PartName}" Width="*"/>
                            <DataGridTextColumn Header="الرقم" Binding="{Binding PartNumber}" Width="90"/>
                            <DataGridTextColumn Header="المخزون" Binding="{Binding CurrentStock}" Width="80" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="تكلفة سابقة" Binding="{Binding PreviousCostPrice, StringFormat='{}{0:N2}'}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="بيع سابق" Binding="{Binding PreviousSalePrice, StringFormat='{}{0:N2}'}" Width="95" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="أدنى سابق" Binding="{Binding PreviousMinSalePriceDisplay}" Width="90" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="الكمية" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Quantity, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center" Padding="2"
                                                 BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="سعر التكلفة" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CostPrice, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center" Padding="2"
                                                 BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="سعر البيع" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding SalePrice, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center" Padding="2"
                                                 BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="أدنى سعر" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding MinSalePrice, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center" Padding="2"
                                                 BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotalDisplay}" Width="115" IsReadOnly="True"/>
                            <DataGridTextColumn Header="الربح" Binding="{Binding ProfitMarginDisplay}" Width="75" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProfitPerUnit}" Value="0">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="حذف" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource IconButton}"
                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="حذف">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#E74C3C"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Supplier & Notes -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="اسم المورد" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SupplierName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="رقم المورد" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SupplierPhone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ملاحظات" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Total & Actions -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2C3E50">
                                <Run Text="الإجمالي: "/><Run Text="{Binding TotalAmountDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource OutlineButton}" Content="مسح السلة"
                                Command="{Binding ClearCartCommand}" MinWidth="80" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Style="{StaticResource SuccessButton}" Content="إتمام الشراء"
                                Command="{Binding CompletePurchaseCommand}" MinWidth="120"/>
                    </Grid>

                    <!-- Status Message -->
                    <Border Background="{Binding IsSuccessMessage, Converter={StaticResource BoolToVisibility}, ConverterParameter='#D4EDDA,#FDEDEC'}"
                            CornerRadius="4" Padding="12,8" Margin="0,8,0,0"
                            Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibility}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#D4EDDA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccessMessage}" Value="False">
                                        <Setter Property="Background" Value="#FDEDEC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#155724"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccessMessage}" Value="False">
                                            <Setter Property="Foreground" Value="#721C24"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- PURCHASE INVOICE LIST (Bottom) -->
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <StackPanel>
                    <TextBlock Text="سجل فواتير المشتريات" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

                    <!-- Date Filters -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="من تاريخ" FontSize="11" Foreground="#64748B"/>
                            <DatePicker SelectedDate="{Binding FilterFromDate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="إلى تاريخ" FontSize="11" Foreground="#64748B"/>
                            <DatePicker SelectedDate="{Binding FilterToDate}"/>
                        </StackPanel>
                        <Button Grid.Column="3" Style="{StaticResource PrimaryButton}" Content="تصفية"
                                Command="{Binding FilterInvoicesCommand}" MinWidth="60" Margin="8,16,0,0"/>
                        <Button Grid.Column="4" Style="{StaticResource OutlineButton}" Content="مسح"
                                Command="{Binding ClearFilterCommand}" MinWidth="50" Margin="4,16,0,0"/>
                    </Grid>

                    <!-- Invoice List -->
                    <DataGrid ItemsSource="{Binding PurchaseInvoices}" SelectedItem="{Binding SelectedPurchaseInvoice}"
                              AutoGenerateColumns="False" MaxHeight="250"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              IsReadOnly="True"
                              MouseDoubleClick="InvoiceList_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="150"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="140"/>
                            <DataGridTextColumn Header="المورد" Binding="{Binding SupplierName}" Width="*"/>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="عدد الأصناف" Binding="{Binding ItemsCount}" Width="100"/>
                            <DataGridTemplateColumn Header="الحالة" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                                                    <Setter Property="Background" Value="#D4EDDA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Background" Value="#F8D7DA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="مكتملة"/>
                                                        <Setter Property="Foreground" Value="#155724"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                <Setter Property="Text" Value="ملغاة"/>
                                                                <Setter Property="Foreground" Value="#721C24"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="إلغاء" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource IconButton}"
                                                Command="{Binding DataContext.CancelPurchaseInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                ToolTip="إلغاء الفاتورة">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#E74C3C"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Grid Margin="0,8,0,0">
                        <TextBlock Style="{StaticResource CaptionStyle}" VerticalAlignment="Center">
                            <Run Text="الصفحة "/><Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                            <Run Text=" من "/><Run Text="{Binding TotalPages, Mode=OneWay}"/>
                        </TextBlock>
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <Button Style="{StaticResource OutlineButton}" Content="السابق"
                                    Command="{Binding PreviousPageCommand}" Margin="0,0,8,0"
                                    Height="28" MinWidth="60" FontSize="11"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="التالي"
                                    Command="{Binding NextPageCommand}"
                                    Height="28" MinWidth="60" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

<Window x:Class="AutoPartsShop.UI.Views.PurchaseInvoices.PurchaseInvoiceDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
        Title="تفاصيل فاتورة المشتريات" Height="700" Width="850"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6FA"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shop Info + Invoice Title -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding ShopName}" FontSize="22" FontWeight="Bold" Foreground="White"
                               Visibility="{Binding HasShopName, Converter={StaticResource BoolToVisConverter}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding ShopAddress}" FontSize="12" Foreground="#94A3B8" Margin="0,0,16,0"
                                   Visibility="{Binding HasShopAddress, Converter={StaticResource BoolToVisConverter}}"/>
                        <TextBlock Text="{Binding ShopPhone}" FontSize="12" Foreground="#94A3B8"
                                   Visibility="{Binding HasShopPhone, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding InvoiceNumber}" FontSize="15" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    <TextBlock Text="فاتورة مشتريات" FontSize="12" Foreground="#64B5F6" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Status Badge -->
                <Border Grid.Column="1" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#DCFCE7"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontWeight="SemiBold" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Setter Property="Text" Value="مكتملة"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                        <Setter Property="Text" Value="ملغاة"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Invoice Info + Items -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Invoice Info Card -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="رقم الفاتورة" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding InvoiceNumber}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="التاريخ" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="المستخدم" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding UserName}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Row 2: Supplier Info -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="اسم المورد" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValue}">
                                        <Setter Property="Text" Value="{Binding SupplierName}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SupplierName}" Value="{x:Null}">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="رقم المورد" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValue}">
                                        <Setter Property="Text" Value="{Binding SupplierPhone}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SupplierPhone}" Value="{x:Null}">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="ملاحظات" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValue}">
                                        <Setter Property="Text" Value="{Binding Notes}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Items Table -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="عناصر الفاتورة" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

                        <!-- Header Row -->
                        <Border Background="#F1F5F9" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="95"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="القطعة" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBlock Grid.Column="2" Text="الكمية" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="سعر التكلفة" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="سعر البيع" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="أدنى سعر" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="الإجمالي" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Items List -->
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,6" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="95"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumber}" FontSize="12" Foreground="#64748B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PartName}" FontSize="12" Foreground="#1E293B" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Quantity}" FontSize="12" Foreground="#1E293B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding CostPrice, StringFormat='{}{0:N2}'}" FontSize="12" Foreground="#1E293B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding SalePrice, StringFormat='{}{0:N2}'}" FontSize="12" Foreground="#1E293B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" FontSize="12" Foreground="#64748B" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding MinSalePriceDisplay}"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="6" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                                        <Binding Path="LineTotal"/>
                                                        <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Totals -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Left side - Item count -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="14" Foreground="#64748B">
                        <Run Text="عدد الأصناف: "/><Run Text="{Binding ItemsCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="#1E293B"/>
                    </TextBlock>
                </StackPanel>

                <!-- Right side - Total -->
                <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Padding="16">
                    <Grid>
                        <TextBlock Text="الإجمالي" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#1E3A5F" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} {1}">
                                    <Binding Path="TotalAmount"/>
                                    <Binding Path="CurrencySymbol"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="إغلاق" Width="120" Height="38" FontSize="14" FontWeight="SemiBold"
                    Click="CloseButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E2E8F0" CornerRadius="6" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="طباعة PDF" Width="120" Height="38" FontSize="14" FontWeight="SemiBold"
                    Margin="12,0,0,0" Click="PrintPdfButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1E3A5F" CornerRadius="6" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D5A8E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

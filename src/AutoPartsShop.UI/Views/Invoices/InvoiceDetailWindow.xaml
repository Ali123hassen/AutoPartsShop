<Window x:Class="AutoPartsShop.UI.Views.Invoices.InvoiceDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
        Title="تفاصيل الفاتورة" Height="750" Width="800"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6FA"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TotalRow" TargetType="Border">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Shop Info -->
        <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shop Info -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                    <TextBlock Text="{Binding ShopName}" FontSize="22" FontWeight="Bold" Foreground="White"
                               Visibility="{Binding HasShopName, Converter={StaticResource BoolToVisConverter}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding ShopAddress}" FontSize="12" Foreground="#94A3B8" Margin="0,0,16,0"
                                   Visibility="{Binding HasShopAddress, Converter={StaticResource BoolToVisConverter}}"/>
                        <TextBlock Text="{Binding ShopPhone}" FontSize="12" Foreground="#94A3B8"
                                   Visibility="{Binding HasShopPhone, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Invoice Number & Status -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="{Binding InvoiceNumber}" FontSize="15" Foreground="#94A3B8"/>
                </StackPanel>

                <Border Grid.Row="0" Grid.Column="1" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FEE2E2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                    <Setter Property="Background" Value="#DCFCE7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="PartialReturn">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="FullReturn">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontWeight="SemiBold" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#DC2626"/>
                                <Setter Property="Text" Value="ملغاة"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                        <Setter Property="Text" Value="مكتملة"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="PartialReturn">
                                        <Setter Property="Foreground" Value="#E65100"/>
                                        <Setter Property="Text" Value="↩ مرتجع جزئي"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="FullReturn">
                                        <Setter Property="Foreground" Value="#757575"/>
                                        <Setter Property="Text" Value="↩ مرتجع كامل"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Invoice Info + Items -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Invoice Info Card -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="رقم الفاتورة" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding InvoiceNumber}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="التاريخ" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="طريقة الدفع" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValue}">
                                        <Setter Property="Text" Value="نقدي"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentMethod}" Value="Card">
                                                <Setter Property="Text" Value="بطاقة"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="اسم العميل" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding CustomerName}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="الكاشير" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Text="{Binding UserName}" Style="{StaticResource DetailValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="ملاحظات" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValue}">
                                        <Setter Property="Text" Value="{Binding Notes}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Items Table -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="عناصر الفاتورة" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

                        <!-- Header Row with conditional cost/sale columns -->
                        <Border Background="#F1F5F9" CornerRadius="4" Padding="12,8" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="95"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBlock Grid.Column="1" Text="المنتج" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBlock Grid.Column="2" Text="الكمية" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="المرتجع" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="المتبقي" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="تكلفة الوحدة" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"
                                           Visibility="{Binding DataContext.ShowCostAndPrice, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Column="6" Text="سعر البيع" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"
                                           Visibility="{Binding DataContext.ShowCostAndPrice, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Grid.Column="7" Text="سعر الوحدة" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="الخصم" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                                <TextBlock Grid.Column="9" Text="الإجمالي" FontSize="11" FontWeight="SemiBold" Foreground="#475569" TextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Items List -->
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,6" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ItemReturnStatus}" Value="PartialReturn">
                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ItemReturnStatus}" Value="FullReturn">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="95"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumber}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="↩" FontSize="11" Foreground="#C62828" Margin="0,0,4,0" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ItemReturnStatus}" Value="PartialReturn">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ItemReturnStatus}" Value="FullReturn">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding PartName}" FontSize="12" Foreground="#1E293B" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Quantity}" FontSize="12" Foreground="#1E293B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding ReturnedQty}" FontSize="12" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#9E9E9E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemReturnStatus}" Value="PartialReturn">
                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemReturnStatus}" Value="FullReturn">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="4" Text="{Binding RemainingQty}" FontSize="12" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemReturnStatus}" Value="FullReturn">
                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- تكلفة الوحدة (مشروطة) -->
                                            <TextBlock Grid.Column="5" FontSize="12" Foreground="#C62828" TextAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding DataContext.ShowCostAndPrice, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                                        <Binding Path="CostAtSale"/>
                                                        <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <!-- سعر البيع (مشروط) -->
                                            <TextBlock Grid.Column="6" FontSize="12" Foreground="#16A34A" TextAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding DataContext.ShowCostAndPrice, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                                        <Binding Path="UnitPrice"/>
                                                        <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Grid.Column="7" Text="{Binding UnitPrice, StringFormat='{}{0:N2}'}" FontSize="12" Foreground="#1E293B" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="8" FontSize="12" Foreground="#64748B" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                                        <Binding Path="DiscountAmountPerUnit"/>
                                                        <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Grid.Column="9" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                                        <Binding Path="LineTotal"/>
                                                        <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Return Financial Summary (only shown when there are returns) -->
                <Border Background="#FFF5F5" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#FECACA" BorderThickness="1"
                        Visibility="{Binding HasReturns, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="↩" FontSize="14" Foreground="#C62828" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تفاصيل المرتجع" FontSize="15" FontWeight="SemiBold" Foreground="#C62828" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- الإجمالي الفرعي للمرتجع (قبل الخصم) -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="الإجمالي الفرعي" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="ReturnSubTotal"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- خصم المرتجع -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="خصم المرتجع" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontSize="13" Foreground="#EF4444" Margin="0,0,0,6">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}-{0:N2} {1}">
                                        <Binding Path="ReturnDiscount"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- المرتجع بعد الخصم -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="بعد الخصم" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="ReturnAfterDiscount"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- ضريبة المرتجع -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding TaxLabel}" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontSize="13" Foreground="#7F1D1D" Margin="0,0,0,6">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="ReturnTax"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- إجمالي المرتجع -->
                            <Border Grid.Row="4" Grid.ColumnSpan="2" Background="#FEE2E2" CornerRadius="4" Padding="8,6" Margin="0,4,0,0">
                                <Grid>
                                    <TextBlock Text="إجمالي المرتجع" FontSize="14" FontWeight="Bold" Foreground="#991B1B" VerticalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="#991B1B" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N2} {1}">
                                                <Binding Path="ReturnTotal"/>
                                                <Binding Path="CurrencySymbol"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Totals -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Left side - Paid info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="المبلغ المدفوع" Style="{StaticResource DetailLabel}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="14" Foreground="#16A34A" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} {1}">
                                    <Binding Path="PaidAmount"/>
                                    <Binding Path="CurrencySymbol"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <Grid>
                        <TextBlock Text="الباقي" Style="{StaticResource DetailLabel}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="14" Foreground="#64748B" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} {1}">
                                    <Binding Path="ChangeAmount"/>
                                    <Binding Path="CurrencySymbol"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- Right side - Totals -->
                <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="الإجمالي الفرعي" FontSize="13" Foreground="#64748B"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="#475569">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="SubTotal"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="{Binding TaxLabel}" FontSize="13" Foreground="#64748B"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="#475569">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="TaxAmount"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="الخصم" FontSize="13" Foreground="#64748B"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="#EF4444">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}-{0:N2} {1}">
                                        <Binding Path="DiscountAmount"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Border Background="#E2E8F0" Height="1" Margin="0,4"/>
                        <Grid Margin="0,6,0,0">
                            <TextBlock Text="الإجمالي" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#1E3A5F">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:N2} {1}">
                                        <Binding Path="TotalAmount"/>
                                        <Binding Path="CurrencySymbol"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
            <CheckBox IsChecked="{Binding ShowCostAndPrice}" Content="إظهار التكلفة وسعر البيع"
                      FontSize="13" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,20,0"
                      Cursor="Hand"/>
            <Button Content="إغلاق" Width="120" Height="38" FontSize="14" FontWeight="SemiBold"
                    Click="CloseButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E2E8F0" CornerRadius="6" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

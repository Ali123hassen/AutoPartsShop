<Page x:Class="AutoPartsShop.UI.Views.Invoices.InvoiceListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      Title="الفواتير" FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="الفواتير" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Date From Filter -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="من:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterFromDate}" Width="140" FontSize="12"/>
                </StackPanel>

                <!-- Date To Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="إلى:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterToDate}" Width="140" FontSize="12"/>
                </StackPanel>

                <!-- Search -->
                <Grid Grid.Column="4">
                    <Border Style="{StaticResource InputGroupStyle}" Width="280">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="8,4"
                                     FontSize="12" FlowDirection="RightToLeft"/>
                            <Button Grid.Column="1" Command="{Binding SearchInvoicesCommand}"
                                    Style="{StaticResource IconButton}" Padding="8"
                                    AutomationProperties.Name="بحث في الفواتير">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ===== Auto-suggest popup ===== -->
                    <!-- Shows matching invoices when the user types 3+ chars of an invoice number -->
                    <Popup IsOpen="{Binding IsSuggestionsOpen}"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=SearchTextBox}"
                           Width="280"
                           MaxHeight="320"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="0"
                                Margin="0,2,0,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.18" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Header -->
                                <Border Background="#F1F5F9" CornerRadius="6,6,0,0" Padding="10,6">
                                    <TextBlock Text="اقتراحات الفواتير"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                </Border>

                                <!-- Suggestions list -->
                                <ItemsControl ItemsSource="{Binding InvoiceSuggestions}" Margin="0,4,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectSuggestionCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Padding="10,8"
                                                    Cursor="Hand"
                                                    FontSize="12">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd"
                                                                            Background="Transparent"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Invoice number -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding InvoiceNumber}"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               Foreground="#1E40AF"/>
                                                    <!-- Customer name (if any) -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CustomerName, TargetNullValue='—'}"
                                                               Margin="12,0,0,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="#64748B"/>
                                                    <!-- Total -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}"
                                                               Foreground="#16A34A"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <!-- Status Message -->
        <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#E65100"/>
        </Border>

        <!-- Invoices Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <DataGrid x:Name="InvoicesDataGrid"
                      ItemsSource="{Binding Invoices}" AutoGenerateColumns="False"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent"
                      FontSize="13" GridLinesVisibility="Horizontal"
                      SelectedItem="{Binding SelectedInvoice}"
                      RowBackground="White" AlternatingRowBackground="#F8FAFC" Padding="8"
                      IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                      MouseDoubleClick="InvoicesDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="140"/>
                    <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="140"/>
                    <DataGridTemplateColumn Header="الإجمالي" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock TextAlignment="Center" VerticalAlignment="Center" FontSize="13">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:N2} {1}">
                                            <Binding Path="TotalAmount"/>
                                            <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding PaymentMethod}" Width="100"/>
                    <DataGridTemplateColumn Header="الحالة" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="PartialReturn">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="FullReturn">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="Text" Value="ملغاة"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Setter Property="Text" Value="مكتملة"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PartialReturn">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                        <Setter Property="Text" Value="مرتجع جزئي"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="FullReturn">
                                                        <Setter Property="Foreground" Value="#757575"/>
                                                        <Setter Property="Text" Value="مرتجع كامل"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="إجراءات" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- View Detail Button -->
                                    <Button Style="{StaticResource IconButton}" ToolTip="عرض التفاصيل" Margin="0,0,4,0"
                                            Command="{Binding DataContext.ViewInvoiceDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="عرض التفاصيل">
                                        <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#1E3A5F"/>
                                    </Button>
                                    <!-- Print Button -->
                                    <Button Style="{StaticResource IconButton}" ToolTip="طباعة الفاتورة" Margin="0,0,4,0"
                                            Command="{Binding DataContext.PrintInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="طباعة الفاتورة">
                                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#1E3A5F"/>
                                    </Button>
                                    <!-- Cancel Button -->
                                    <Button Style="{StaticResource IconButton}" ToolTip="إلغاء الفاتورة" Margin="0,0,4,0"
                                            Command="{Binding DataContext.CancelInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="إلغاء الفاتورة">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource DangerBrush}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding PreviousPageCommand}" Style="{StaticResource OutlineButton}"
                        Height="32" FontSize="12" Padding="12,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE760;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Text="السابق"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding TotalCount, StringFormat='إجمالي {0} فاتورة'}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="2" Command="{Binding NextPageCommand}" Style="{StaticResource OutlineButton}"
                        Height="32" FontSize="12" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="التالي"/>
                        <TextBlock Text="&#xE761;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>

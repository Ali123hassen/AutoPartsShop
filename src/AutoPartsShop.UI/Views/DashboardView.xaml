<Page x:Class="AutoPartsShop.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="لوحة التحكم">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="16">

            <!-- ===== رأس لوحة التحكم ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                        <Run Text="{Binding WelcomeMessage}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding ShopName}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding TodayDateDisplay}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Style="{StaticResource OutlineButton}" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== بطاقات الإحصائيات الرئيسية ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- مبيعات اليوم -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#1976D2" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="مبيعات اليوم" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodaySalesDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="&#xE910;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource SuccessBrush}" Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayInvoices, StringFormat='{}{0} فاتورة'}"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- أرباح اليوم -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#388E3C" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="أرباح اليوم" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayProfitDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="هامش الربح: " FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayProfitMarginDisplay}" FontSize="11"
                                       FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- مرتجعات اليوم -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,8,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#FFF3E0" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#F57C00" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="مرتجعات اليوم" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayReturnsDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource WarningBrush}" Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayReturnCount, StringFormat='{}{0} مرتجع'}"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- فواتير اليوم -->
                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#F3E5F5" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#7B1FA2" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="فواتير اليوم" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayInvoices}" FontSize="24" FontWeight="Bold"
                                   Foreground="#7B1FA2" Margin="0,4,0,0"/>
                        <TextBlock Text="إجمالي الفواتير" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== بطاقات المخزون ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- قيمة المخزون -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#E0F7FA" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE912;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#00838F" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="قيمة المخزون" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalStockValueDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="#00838F" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="&#xE910;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalParts, StringFormat='{}{0} قطعة'}"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- منخفض المخزون -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#FBE9E7" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#D84315" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="تنبيهات المخزون" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LowStockDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="قطعة منخفضة المخزون" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- نفد المخزون -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="#C62828" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="نفد المخزون" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OutOfStockDisplay}" FontSize="24" FontWeight="Bold"
                                   Foreground="#C62828" Margin="0,4,0,0"/>
                        <TextBlock Text="قطعة غير متوفرة" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== الرسم البياني ===== -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="المبيعات والأرباح - آخر 7 أيام" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,16"/>
                    <lvc:CartesianChart Series="{Binding SalesChartSeries}"
                                        XAxes="{Binding SalesChartXAxes}"
                                        YAxes="{Binding SalesChartYAxes}"
                                        Height="250"
                                        Background="Transparent"/>
                </StackPanel>
            </Border>

            <!-- ===== الأكثر مبيعاً + آخر الفواتير ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- الأكثر مبيعاً -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="الأكثر مبيعاً هذا الشهر" FontSize="16" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding TopSellingParts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="4"
                                                    Padding="6,4" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding NetQuantitySold}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#1976D2"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PartName}" FontWeight="SemiBold"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding PartNumber}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding NetRevenue, StringFormat='{}{0:N0}'}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="لا توجد بيانات" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TopSellingParts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- آخر الفواتير -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="آخر الفواتير" FontSize="16" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding RecentInvoices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding InvoiceNumber}"
                                                       FontWeight="SemiBold" FontSize="13" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CustomerName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="لا توجد فواتير" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentInvoices.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== قطع منخفضة المخزون ===== -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock Text="قطع منخفضة المخزون" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding LowStockItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding PartNumber}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding MinStockLevel, StringFormat='{}حد أدنى: {0}'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="{Binding CurrentStock, StringFormat='{}{0} قطعة'}"
                                                       FontSize="12" Foreground="#E65100" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="لا توجد قطع منخفضة المخزون" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LowStockItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="AutoPartsShop.UI.Views.Reports.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      Title="التقارير" FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:ReportTypeToCardBgConverter x:Key="ReportTypeToCardBgConverter"/>
        <converters:ReportTypeToCardBorderConverter x:Key="ReportTypeToCardBorderConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Page Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="التقارير" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,0"/>
                    <TextBlock Text="تحليل شامل لأداء المتجر والمبيعات والمخزون" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Report Type Cards -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="اختر نوع التقرير" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Daily Sales Report -->
                        <Border Grid.Column="0" Margin="0,0,6,0" Padding="16,12" CornerRadius="6" Cursor="Hand"
                                Background="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBgConverter}, ConverterParameter=0}"
                                BorderThickness="2"
                                BorderBrush="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBorderConverter}, ConverterParameter=0}"
                                MouseLeftButtonUp="ReportTypeCard_Click" Tag="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#1A1A5276" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="تقرير المبيعات" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="يومي / شهري" HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Profit Report -->
                        <Border Grid.Column="1" Margin="6,0,6,0" Padding="16,12" CornerRadius="6" Cursor="Hand"
                                Background="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBgConverter}, ConverterParameter=1}"
                                BorderThickness="2"
                                BorderBrush="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBorderConverter}, ConverterParameter=1}"
                                MouseLeftButtonUp="ReportTypeCard_Click" Tag="1">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#1A27AE60" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="تقرير الأرباح" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="إيرادات / مصروفات" HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stock Report -->
                        <Border Grid.Column="2" Margin="6,0,6,0" Padding="16,12" CornerRadius="6" Cursor="Hand"
                                Background="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBgConverter}, ConverterParameter=2}"
                                BorderThickness="2"
                                BorderBrush="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBorderConverter}, ConverterParameter=2}"
                                MouseLeftButtonUp="ReportTypeCard_Click" Tag="2">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#1AF39C12" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8DE;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="تقرير المخزون" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="حركة / جرد" HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Top Selling Report -->
                        <Border Grid.Column="3" Margin="6,0,6,0" Padding="16,12" CornerRadius="6" Cursor="Hand"
                                Background="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBgConverter}, ConverterParameter=3}"
                                BorderThickness="2"
                                BorderBrush="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBorderConverter}, ConverterParameter=3}"
                                MouseLeftButtonUp="ReportTypeCard_Click" Tag="3">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#1A3498DB" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="الأكثر مبيعاً" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="ترتيب / كمية" HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Returns Report -->
                        <Border Grid.Column="4" Margin="6,0,0,0" Padding="16,12" CornerRadius="6" Cursor="Hand"
                                Background="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBgConverter}, ConverterParameter=4}"
                                BorderThickness="2"
                                BorderBrush="{Binding SelectedReportType, Converter={StaticResource ReportTypeToCardBorderConverter}, ConverterParameter=4}"
                                MouseLeftButtonUp="ReportTypeCard_Click" Tag="4">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#1AE74C3C" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="تقرير المرتجعات" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="استبدال / استرجاع" HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Date Range & Actions Bar -->
            <Border Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="من تاريخ:" VerticalAlignment="Center" FontWeight="Medium" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" Width="150" Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2" Text="إلى تاريخ:" VerticalAlignment="Center" FontWeight="Medium" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="3" SelectedDate="{Binding ToDate}" Width="150" Margin="0,0,16,0"/>

                    <Button Grid.Column="4" Command="{Binding GenerateReportCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إنشاء التقرير" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5" Command="{Binding PrintReportCommand}" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"
                            IsEnabled="{Binding HasReport}" Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="طباعة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="6" Command="{Binding ExportReportCommand}" Style="{StaticResource AccentButton}"
                            IsEnabled="{Binding HasReport}" Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تصدير PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Loading Indicator -->
            <Border Style="{StaticResource CardStyle}" Padding="40" Margin="0,0,0,16"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,12"/>
                    <TextBlock Text="جاري إنشاء التقرير..." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Report Content Area -->
            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <!-- Report Title -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ReportTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ReportDateDisplay}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sales Report Content -->
                    <StackPanel Visibility="{Binding IsDailySalesReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding DailySalesData}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 1: Main Sales Metrics (Net after returns) -->
                                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,6,8" Padding="14" CornerRadius="6" Background="#F0F7FF">
                                            <StackPanel>
                                                <TextBlock Text="المبيعات (قبل الخصم)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding TotalSalesBeforeDiscount, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding TotalInvoices, StringFormat='{}{0} فاتورة'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="1" Margin="6,0,6,8" Padding="14" CornerRadius="6" Background="#FFF3E0">
                                            <StackPanel>
                                                <TextBlock Text="الخصومات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding TotalDiscounts, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#E65100"/>
                                                <TextBlock Text="بعد خصم المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="2" Margin="6,0,6,8" Padding="14" CornerRadius="6" Background="#E3F2FD">
                                            <StackPanel>
                                                <TextBlock Text="المبيعات بعد الخصم" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding TotalSales, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#1565C0"/>
                                                <TextBlock Text="صافي المبيعات (قبل الضريبة)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="3" Margin="6,0,0,8" Padding="14" CornerRadius="6" Background="#EDE7F6">
                                            <StackPanel>
                                                <TextBlock Text="صافي الضريبة" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding NetTax, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#7B1FA2"/>
                                                <TextBlock Text="بعد خصم ضريبة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Row 2: Returns Details -->
                                        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,6,8" Padding="14" CornerRadius="6" Background="#FCE4EC">
                                            <StackPanel>
                                                <TextBlock Text="المرتجعات (قبل الخصم)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ReturnsBeforeDiscount, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                                <TextBlock Text="سعر الوحدة الأصلي × الكمية" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="1" Margin="6,0,6,8" Padding="14" CornerRadius="6" Background="#FCE4EC">
                                            <StackPanel>
                                                <TextBlock Text="المرتجعات (بعد الخصم)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding TotalReturnsBeforeTax, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                                <TextBlock Text="قبل الضريبة" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="2" Margin="6,0,6,8" Padding="14" CornerRadius="6" Background="#FFF3E0">
                                            <StackPanel>
                                                <TextBlock Text="ضريبة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ReturnsTax, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#E65100"/>
                                                <TextBlock Text="المسترجعة للعملاء" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="3" Margin="6,0,0,8" Padding="14" CornerRadius="6" Background="#FFF8E1">
                                            <StackPanel>
                                                <TextBlock Text="تكلفة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ReturnedCost, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#F57F17"/>
                                                <TextBlock Text="تكلفة الأصناف المرتجعة" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Row 3: Costs + Profit -->
                                        <Border Grid.Row="2" Grid.Column="0" Margin="0,0,6,8" Padding="14" CornerRadius="6" Background="#FFEBEE">
                                            <StackPanel>
                                                <TextBlock Text="صافي التكاليف" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding NetCost, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                                <TextBlock Text="بعد خصم تكلفة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="6,0,0,8" Padding="16" CornerRadius="6" Background="#E8F5E9">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="صافي الربح" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="صافي المبيعات - صافي التكاليف" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding TotalProfit, StringFormat='{}{0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Profit Report Content -->
                    <StackPanel Visibility="{Binding IsProfitReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Row 1: Revenue Metrics (Net after returns) -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0" Padding="16" CornerRadius="6" Background="#F0F7FF">
                                <StackPanel>
                                    <TextBlock Text="الإيرادات (قبل الخصم)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.TotalRevenueBeforeDiscount, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ProfitData.TotalItemsSold, StringFormat='{}{0} قطعة'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="6,0,6,0" Padding="16" CornerRadius="6" Background="#FFF3E0">
                                <StackPanel>
                                    <TextBlock Text="الخصومات" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.TotalDiscounts, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
                                    <TextBlock Text="بعد خصم المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="6,0,6,0" Padding="16" CornerRadius="6" Background="#E3F2FD">
                                <StackPanel>
                                    <TextBlock Text="الإيرادات (بعد الخصم)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.TotalRevenue, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#1565C0"/>
                                    <TextBlock Text="صافي الإيرادات (قبل الضريبة)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="6,0,0,0" Padding="16" CornerRadius="6" Background="#EDE7F6">
                                <StackPanel>
                                    <TextBlock Text="صافي الضريبة" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.NetTax, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#7B1FA2"/>
                                    <TextBlock Text="بعد خصم ضريبة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Row 2: Returns Details -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0" Padding="16" CornerRadius="6" Background="#FCE4EC">
                                <StackPanel>
                                    <TextBlock Text="المرتجعات (قبل الخصم)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.ReturnsBeforeDiscount, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="سعر الوحدة الأصلي × الكمية" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="6,0,6,0" Padding="16" CornerRadius="6" Background="#FCE4EC">
                                <StackPanel>
                                    <TextBlock Text="المرتجعات (بعد الخصم)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.TotalReturnsBeforeTax, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="قبل الضريبة" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="6,0,6,0" Padding="16" CornerRadius="6" Background="#FFF3E0">
                                <StackPanel>
                                    <TextBlock Text="ضريبة المرتجعات" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.ReturnsTax, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
                                    <TextBlock Text="المسترجعة للعملاء" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="6,0,0,0" Padding="16" CornerRadius="6" Background="#FFF8E1">
                                <StackPanel>
                                    <TextBlock Text="تكلفة المرتجعات" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.ReturnedCost, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#F57F17"/>
                                    <TextBlock Text="تكلفة الأصناف المرتجعة" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Row 3: Net Cost + Net Profit + Profit Margin -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0" Padding="16" CornerRadius="6" Background="#FFEBEE">
                                <StackPanel>
                                    <TextBlock Text="صافي التكاليف" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.NetCost, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="بعد خصم تكلفة المرتجعات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="6,0,6,0" Padding="16" CornerRadius="6" Background="#E8F5E9">
                                <StackPanel>
                                    <TextBlock Text="صافي الربح" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.RealNetProfit, StringFormat='{}{0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="صافي الإيرادات - صافي التكاليف" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="6,0,0,0" Padding="16" CornerRadius="6" Background="#F0FFF4">
                                <StackPanel>
                                    <TextBlock Text="هامش الربح" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ProfitData.ProfitMargin, StringFormat='{}{0}%'}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="نسبة الربح من صافي الإيرادات" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Stock Report Content -->
                    <StackPanel Visibility="{Binding IsStockReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,8,0" Padding="16" CornerRadius="6" Background="#F0F7FF">
                                <StackPanel>
                                    <TextBlock Text="إجمالي القطع" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding StockData.TotalParts}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="نوع قطعة غيار" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="8,0,8,0" Padding="16" CornerRadius="6" Background="#FFF8E1">
                                <StackPanel>
                                    <TextBlock Text="مخزون منخفض" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding StockData.LowStockParts}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                    <TextBlock Text="تحتاج إعادة طلب" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="8,0,8,0" Padding="16" CornerRadius="6" Background="#FFEBEE">
                                <StackPanel>
                                    <TextBlock Text="نفذ المخزون" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding StockData.OutOfStockParts}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="قطعة غير متوفرة" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="8,0,0,0" Padding="16" CornerRadius="6" Background="#F0FFF4">
                                <StackPanel>
                                    <TextBlock Text="قيمة المخزون" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding StockData.TotalStockValue, StringFormat='{}{0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="بسعر الشراء" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Stock Summary Bar -->
                        <Border Background="#F8F9FA" CornerRadius="6" Padding="16" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="نسبة القطع المتوفرة" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AvailableStockPercent, StringFormat='{}{0}%'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="نسبة المنخفض" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LowStockPercent, StringFormat='{}{0}%'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="نسبة النافد" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding OutOfStockPercent, StringFormat='{}{0}%'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Top Selling Report Content -->
                    <StackPanel Visibility="{Binding IsTopSellingReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="القطع الأكثر مبيعاً" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <DataGrid ItemsSource="{Binding TopSellingData}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  MinHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding SparePartId}" Width="50"/>
                                <DataGridTextColumn Header="اسم القطعة" Binding="{Binding PartName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="رقم القطعة" Binding="{Binding PartNumber}" Width="110"/>
                                <DataGridTextColumn Header="السعر" Binding="{Binding UnitPrice, StringFormat='{}{0:N2}'}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="الكمية المباعة" Binding="{Binding TotalQuantitySold}" Width="100"/>
                                <DataGridTextColumn Header="المرتجع" Binding="{Binding ReturnedQuantity}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="صافي الكمية" Binding="{Binding NetQuantitySold}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="إجمالي الخصم" Binding="{Binding TotalDiscount, StringFormat='{}{0:N2}'}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="إجمالي الإيرادات" Binding="{Binding TotalRevenue, StringFormat='{}{0:N2}'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="إيراد المرتجع" Binding="{Binding ReturnedRevenue, StringFormat='{}{0:N2}'}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="صافي الإيرادات" Binding="{Binding NetRevenue, StringFormat='{}{0:N2}'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Returns Report Content -->
                    <StackPanel Visibility="{Binding IsReturnsReport, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="سجل المرتجعات" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <DataGrid ItemsSource="{Binding ReturnsData}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  MinHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم المرتجع" Binding="{Binding ReturnNumber}" Width="130"/>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="130"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding ReturnDate, StringFormat='{}{0:yyyy/MM/dd}'}" Width="110"/>
                                <DataGridTextColumn Header="النوع" Binding="{Binding ReturnType}" Width="100"/>
                                <DataGridTextColumn Header="اسم القطعة" Binding="{Binding PartName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="المبلغ المسترجع" Binding="{Binding RefundAmount, StringFormat='{}{0:N2}'}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="150"/>
                                <DataGridTextColumn Header="بواسطة" Binding="{Binding UserName}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Empty State (when no report is generated) -->
            <Border Style="{StaticResource CardStyle}" Padding="40" Margin="0,0,0,16"
                    Visibility="{Binding HasReport, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="56" Foreground="#D0D5DD" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="اختر نوع التقرير وحدد الفترة الزمنية" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="ثم اضغط على زر 'إنشاء التقرير' لعرض البيانات" FontSize="13" Foreground="#ADB5BD" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

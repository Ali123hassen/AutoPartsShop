<Page x:Class="AutoPartsShop.UI.Views.Returns.ReturnView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      xmlns:models="clr-namespace:AutoPartsShop.UI.Models"
      Title="المرتجعات" FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- === Toolbar === -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="المرتجعات والاستبدال" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Date From Filter -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="من:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterFromDate}" Width="140" FontSize="12"/>
                </StackPanel>

                <!-- Date To Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="إلى:" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterToDate}" Width="140" FontSize="12"/>
                </StackPanel>

                <!-- Add Return Button -->
                <Button Grid.Column="4" Command="{Binding OpenAddDialogCommand}"
                        Style="{StaticResource AccentButton}" Height="38" Padding="16,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="مرتجع جديد"/>
                    </StackPanel>
                </Button>

                <!-- Refresh Button -->
                <Button Grid.Column="5" Command="{Binding RefreshReturnsCommand}" Style="{StaticResource OutlineButton}"
                        Height="36" FontSize="12" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="تحديث"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- === Status Message === -->
        <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" Foreground="#E65100"/>
                <Button Grid.Column="1" Click="DismissStatus_Click" Style="{StaticResource IconButton}"
                        ToolTip="إغلاق" Padding="4"
                        AutomationProperties.Name="إغلاق">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </Button>
            </Grid>
        </Border>

        <!-- === Returns DataGrid === -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <DataGrid x:Name="ReturnsDataGrid"
                      ItemsSource="{Binding Returns}" AutoGenerateColumns="False"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent"
                      FontSize="13" GridLinesVisibility="Horizontal"
                      SelectedItem="{Binding SelectedReturn}"
                      RowBackground="White" AlternatingRowBackground="#F8FAFC" Padding="8"
                      IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                      MouseDoubleClick="ReturnsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <!-- View Details Button -->
                    <DataGridTemplateColumn Header="التفاصيل" Width="Auto" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ViewReturnDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource OutlineButton}" Height="30" Padding="10,0" FontSize="11"
                                        ToolTip="عرض التفاصيل">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                        <TextBlock Text="تفاصيل"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Return Number -->
                    <DataGridTemplateColumn Header="رقم المرتجع" Width="Auto" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ReturnNumber}" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding ReturnNumber}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Invoice Number (clickable to copy) -->
                    <DataGridTemplateColumn Header="رقم الفاتورة" Width="Auto" MinWidth="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding InvoiceNumber}" VerticalAlignment="Center" Margin="4,0"
                                           Cursor="Hand" Foreground="#1565C0" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" ToolTip="انقر لنسخ رقم الفاتورة"
                                           MouseLeftButtonUp="InvoiceNumber_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding ReturnDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="130"/>

                    <!-- Product -->
                    <DataGridTextColumn Header="المنتج" Binding="{Binding PartName}" Width="*"/>

                    <!-- Quantity -->
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="70"/>

                    <!-- Refund Amount -->
                    <DataGridTemplateColumn Header="مبلغ الاسترداد" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock TextAlignment="Center" VerticalAlignment="Center" FontSize="13">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:N2} {1}">
                                            <Binding Path="RefundAmount"/>
                                            <Binding Path="DataContext.CurrencySymbol" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Return Type (Refund/Exchange) -->
                    <DataGridTemplateColumn Header="النوع" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ReturnType}" Value="Refund">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                <Setter Property="Text" Value="استبدال"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReturnType}" Value="Refund">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                        <Setter Property="Text" Value="استرجاع"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Reason -->
                    <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="150"/>

                    <!-- User -->
                    <DataGridTextColumn Header="المستخدم" Binding="{Binding UserName}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- === Pagination === -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding PreviousPageCommand}" Style="{StaticResource OutlineButton}"
                        Height="32" FontSize="12" Padding="12,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE760;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Text="السابق"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding TotalCount, StringFormat='إجمالي {0} مرتجع'}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="2" Command="{Binding NextPageCommand}" Style="{StaticResource OutlineButton}"
                        Height="32" FontSize="12" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="التالي"/>
                        <TextBlock Text="&#xE761;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- === Add Return Dialog (Overlay) - NEW === -->
        <!-- ============================================ -->
        <Border Grid.RowSpan="4" Background="#80000000" CornerRadius="0"
                Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVisConverter}}"
                Panel.ZIndex="100">
            <Border Background="White" CornerRadius="8" Width="900" MaxHeight="850"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Dialog Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="تسجيل مرتجع جديد" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Grid.Column="1" Command="{Binding CloseAddDialogCommand}"
                                Style="{StaticResource IconButton}" Padding="4"
                                AutomationProperties.Name="إغلاق">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Dialog Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- ===== Step 1: Search Invoice ===== -->
                            <Border Background="#F0F4FF" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="الخطوة ١: البحث عن فاتورة" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1565C0" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Search box + suggestions popup container -->
                                        <Grid Grid.Column="0" Margin="0,0,8,0">
                                            <TextBox x:Name="InvoiceSearchBox" Text="{Binding InvoiceSearch, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="40" FontSize="14" FlowDirection="RightToLeft" Background="Transparent"/>
                                            <TextBlock Text="أدخل رقم الفاتورة..." IsHitTestVisible="False"
                                                       Foreground="Gray" VerticalAlignment="Center" Margin="8,0"
                                                       FontSize="14" FlowDirection="RightToLeft">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=InvoiceSearchBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- ===== Auto-suggest popup ===== -->
                                            <!-- Shows matching invoices when the user types 3+ chars of an invoice number -->
                                            <Popup IsOpen="{Binding IsInvoiceSuggestionsOpen}"
                                                   Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=InvoiceSearchBox}"
                                                   Width="{Binding ActualWidth, ElementName=InvoiceSearchBox}"
                                                   MaxHeight="320"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="False">
                                                <Border Background="White"
                                                        BorderBrush="#CBD5E1"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="0"
                                                        Margin="0,2,0,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.18" Direction="270"/>
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <!-- Header -->
                                                        <Border Background="#F1F5F9" CornerRadius="6,6,0,0" Padding="10,6">
                                                            <TextBlock Text="اقتراحات الفواتير"
                                                                       FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                                        </Border>

                                                        <!-- Suggestions list -->
                                                        <ItemsControl ItemsSource="{Binding InvoiceSuggestions}" Margin="0,4,0,4">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Command="{Binding DataContext.SelectInvoiceSuggestionCommand,
                                                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                                                            CommandParameter="{Binding}"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalContentAlignment="Stretch"
                                                                            Padding="10,8"
                                                                            Cursor="Hand"
                                                                            FontSize="12">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                                <Setter Property="Foreground" Value="#1E293B"/>
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border x:Name="Bd"
                                                                                                    Background="Transparent"
                                                                                                    Padding="{TemplateBinding Padding}">
                                                                                                <ContentPresenter HorizontalAlignment="Stretch"
                                                                                                                  VerticalAlignment="Center"/>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Style>
                                                                        </Button.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- Invoice number -->
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding InvoiceNumber}"
                                                                                       FontWeight="SemiBold"
                                                                                       FontFamily="Consolas"
                                                                                       Foreground="#1E40AF"/>
                                                                            <!-- Customer name (if any) -->
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding CustomerName, TargetNullValue='—'}"
                                                                                       Margin="12,0,0,0"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       Foreground="#64748B"/>
                                                                            <!-- Total -->
                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}"
                                                                                       Foreground="#16A34A"
                                                                                       FontWeight="SemiBold"/>
                                                                        </Grid>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>

                                        <Button Grid.Column="1" Command="{Binding SearchInvoiceCommand}"
                                                Style="{StaticResource PrimaryButton}" Height="40" Padding="20,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="بحث" FontSize="13"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Step 2: Invoice Info ===== -->
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                    Visibility="{Binding HasFoundInvoice, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <TextBlock Text="الخطوة ٢: معلومات الفاتورة" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#2E7D32" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Invoice Number -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="رقم الفاتورة" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding FoundInvoice.InvoiceNumber}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>

                                        <!-- Customer -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="العميل" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding FoundInvoice.CustomerName}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>

                                        <!-- Date -->
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="التاريخ" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding FoundInvoice.InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>

                                        <!-- Employee -->
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="الموظف" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding FoundInvoice.UserName}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Step 3: Invoice Items Table ===== -->
                            <Border Background="#FFF8E1" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                    Visibility="{Binding HasFoundInvoice, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <TextBlock Text="الخطوة ٣: اختيار القطع المرتجعة" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#F57F17" Margin="0,0,0,10"/>

                                    <!-- Items DataGrid with checkboxes -->
                                    <DataGrid ItemsSource="{Binding InvoiceItems}" AutoGenerateColumns="False"
                                              BorderThickness="1" BorderBrush="#E0E0E0" Background="White"
                                              FontSize="12" GridLinesVisibility="All" RowHeight="42"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              SelectionMode="Single" HeadersVisibility="Column"
                                              MaxHeight="300">
                                        <DataGrid.Columns>

                                            <!-- Checkbox Column -->
                                            <DataGridTemplateColumn Header="اختيار" Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate DataType="{x:Type models:InvoiceReturnItemModel}">
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  IsEnabled="{Binding CanReturn}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Part Name -->
                                            <DataGridTextColumn Header="اسم القطعة" Binding="{Binding PartName}" Width="*" IsReadOnly="True"/>

                                            <!-- Part Number -->
                                            <DataGridTextColumn Header="رقم القطعة" Binding="{Binding PartNumber}" Width="90" IsReadOnly="True"/>

                                            <!-- Sold Quantity -->
                                            <DataGridTemplateColumn Header="الكمية المباعة" Width="90" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SoldQuantity}" TextAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="#1565C0" FontWeight="SemiBold"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Previously Returned -->
                                            <DataGridTemplateColumn Header="المرتجع سابقاً" Width="95" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding PreviouslyReturnedQuantity}" TextAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="#E65100" FontWeight="SemiBold"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Available to Return -->
                                            <DataGridTemplateColumn Header="المتاح للإرجاع" Width="95" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding AvailableToReturn}" TextAlignment="Center" VerticalAlignment="Center"
                                                                   FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AvailableToReturn}" Value="0">
                                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Unit Price -->
                                            <DataGridTemplateColumn Header="السعر" Width="80" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N2}'}" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Discount -->
                                            <DataGridTemplateColumn Header="الخصم" Width="90" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock TextAlignment="Center" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#757575"/>
                                                                        <Setter Property="Text" Value="-"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DiscountAmount}" Value="0">
                                                                                <Setter Property="Text" Value="-"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0:N2} ({1}%)">
                                                                        <Binding Path="DiscountAmountPerUnit"/>
                                                                        <Binding Path="DiscountPercent"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Return Quantity (Editable) -->
                                            <DataGridTemplateColumn Header="كمية الإرجاع" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate DataType="{x:Type models:InvoiceReturnItemModel}">
                                                        <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                 TextAlignment="Center" VerticalAlignment="Center"
                                                                 Height="28" FontSize="12" Padding="4,0"
                                                                 IsEnabled="{Binding IsSelected}">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox">
                                                                    <Setter Property="Background" Value="White"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                                            <Setter Property="Background" Value="#F5F5F5"/>
                                                                            <Setter Property="IsReadOnly" Value="True"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Return Type & Details ===== -->
                            <Border Background="#F3E5F5" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                    Visibility="{Binding HasFoundInvoice, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <TextBlock Text="تفاصيل المرتجع" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#7B1FA2" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Return Type -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="نوع المرتجع" FontSize="12" Foreground="#9C27B0" Margin="0,0,0,4"/>
                                            <ComboBox SelectedIndex="{Binding SelectedReturnTypeIndex}" Height="38" FontSize="13">
                                                <ComboBoxItem Content="استرجاع (استرداد نقدي)"/>
                                                <ComboBoxItem Content="استبدال (تبديل بقطعة أخرى)"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Replacement Part (only for Exchange) -->
                                        <StackPanel Grid.Column="1"
                                                    Visibility="{Binding IsExchangeType, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="قطعة الاستبدال" FontSize="12" Foreground="#9C27B0" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding ReplacementParts}" SelectedItem="{Binding SelectedReplacementPart}"
                                                      DisplayMemberPath="Name" Height="38" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Reason -->
                                    <TextBlock Text="سبب المرتجع" FontSize="12" Foreground="#9C27B0" Margin="0,12,0,4"/>
                                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" FlowDirection="RightToLeft" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== Total Summary ===== -->
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="16" Margin="0,0,0,0"
                                    Visibility="{Binding HasFoundInvoice, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <!-- Row 1: Items count + Subtotal -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="القطع المختارة: " FontSize="13" Foreground="#1565C0"/>
                                            <TextBlock Text="{Binding SelectedItemsCount}" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,16,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="الإجمالي قبل الضريبة: " FontSize="13" Foreground="#1565C0"/>
                                            <TextBlock Text="{Binding TotalRefundBeforeTax, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="13" Foreground="#0D47A1"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 2: Discount -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="الخصم: " FontSize="13" Foreground="#C62828"/>
                                            <TextBlock Text="{Binding TotalDiscountAmount, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#C62828" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="13" Foreground="#C62828"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 3: Tax -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="الضريبة: " FontSize="13" Foreground="#E65100"/>
                                            <TextBlock Text="{Binding TotalTaxAmount, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#E65100" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="13" Foreground="#E65100"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 3: Grand Total with line -->
                                    <Border BorderThickness="0,1,0,0" BorderBrush="#90CAF9" Padding="0,6,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="إجمالي الاسترداد: " FontSize="14" FontWeight="Bold" Foreground="#0D47A1"/>
                                                <TextBlock Text="{Binding TotalRefundAmount, StringFormat='{}{0:N2}'}" FontSize="16" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding CurrencySymbol}" FontSize="14" FontWeight="Bold" Foreground="#0D47A1"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Dialog Footer -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1" Command="{Binding SubmitReturnCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Height="42" Padding="24,0"
                                IsEnabled="{Binding IsSubmitting, Converter={StaticResource InvertBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="تسجيل المرتجع" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding CloseAddDialogCommand}"
                                Style="{StaticResource SecondaryButton}" Height="42" Padding="20,0">
                            <TextBlock Text="إلغاء" FontSize="13"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <!-- ============================================ -->
        <!-- === Return Detail Dialog (Overlay) === -->
        <!-- ============================================ -->
        <Border Grid.RowSpan="4" Background="#80000000" CornerRadius="0"
                Visibility="{Binding IsDetailDialogOpen, Converter={StaticResource BoolToVisConverter}}"
                Panel.ZIndex="200">
            <Border Background="White" CornerRadius="8" Width="700" MaxHeight="750"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Detail Dialog Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                                       Foreground="#1565C0" VerticalAlignment="Center"/>
                            <TextBlock Text="تفاصيل المرتجع" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseDetailDialogCommand}"
                                Style="{StaticResource IconButton}" Padding="4"
                                AutomationProperties.Name="إغلاق">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Detail Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- ===== Return Number & Type Badge ===== -->
                            <Border Background="#F0F4FF" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Return Number -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="رقم المرتجع" FontSize="11" Foreground="#90A4AE" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding ReturnDetail.ReturnNumber}" FontSize="16" FontWeight="Bold" Foreground="#0D47A1"/>
                                    </StackPanel>

                                    <!-- Return Date -->
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock Text="تاريخ المرتجع" FontSize="11" Foreground="#90A4AE" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding ReturnDetail.ReturnDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" FontSize="14" FontWeight="SemiBold" Foreground="#37474F"/>
                                    </StackPanel>

                                    <!-- Return Type Badge -->
                                    <Border Grid.Column="2" CornerRadius="12" Padding="16,4" Margin="20,0,0,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDetailRefundType}" Value="True">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="SemiBold" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                    <Setter Property="Text" Value="استبدال"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDetailRefundType}" Value="True">
                                                            <Setter Property="Foreground" Value="#E65100"/>
                                                            <Setter Property="Text" Value="استرجاع"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ===== Invoice Info ===== -->
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                    Visibility="{Binding HasDetailInvoice, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <TextBlock Text="معلومات الفاتورة" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#2E7D32" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Invoice Number -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="رقم الفاتورة" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.InvoiceNumber}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"
                                                       Cursor="Hand" ToolTip="انقر لنسخ رقم الفاتورة"
                                                       MouseLeftButtonUp="InvoiceNumberDetail_Click"/>
                                        </StackPanel>

                                        <!-- Customer -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="العميل" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.CustomerName}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>

                                        <!-- Invoice Date -->
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="تاريخ الفاتورة" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.InvoiceDate, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>

                                        <!-- Invoice Employee -->
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="موظف الفاتورة" FontSize="11" Foreground="#66BB6A" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.InvoiceUserName}" FontSize="13" FontWeight="SemiBold" Foreground="#1B5E20"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Product Info ===== -->
                            <Border Background="#FFF8E1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="معلومات المنتج" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#F57F17" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Part Name -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="اسم القطعة" FontSize="11" Foreground="#FFA726" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.PartName}" FontSize="14" FontWeight="SemiBold" Foreground="#E65100"/>
                                        </StackPanel>

                                        <!-- Part Number -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="رقم القطعة" FontSize="11" Foreground="#FFA726" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.PartNumber}" FontSize="14" FontWeight="SemiBold" Foreground="#E65100"/>
                                        </StackPanel>

                                        <!-- Quantity -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="الكمية المرتجعة" FontSize="11" Foreground="#FFA726" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ReturnDetail.Quantity}" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Replacement Part (only for Exchange) -->
                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding IsDetailExchangeType, Converter={StaticResource BoolToVisConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="قطعة الاستبدال: " FontSize="13" FontWeight="SemiBold" Foreground="#7B1FA2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#F3E5F5" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ReturnDetail.ReplacementPartName}" FontSize="13" FontWeight="SemiBold" Foreground="#7B1FA2"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Financial Breakdown ===== -->
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="التفاصيل المالية" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#1565C0" Margin="0,0,0,10"/>

                                    <!-- Unit Price -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="سعر الوحدة" FontSize="13" Foreground="#546E7A"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ReturnDetail.UnitPrice, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="12" Foreground="#0D47A1"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Discount -->
                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding HasDetailDiscount, Converter={StaticResource BoolToVisConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="الخصم" FontSize="13" Foreground="#C62828"/>
                                            <TextBlock Text="{Binding ReturnDetail.DiscountPercent, StringFormat='{} ({0}%)'}" FontSize="11" Foreground="#E57373" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="-" FontSize="13" Foreground="#C62828" Margin="0,0,2,0"/>
                                            <TextBlock Text="{Binding ReturnDetail.DiscountAmount, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#C62828" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="12" Foreground="#C62828"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Price After Discount -->
                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding HasDetailDiscount, Converter={StaticResource BoolToVisConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="السعر بعد الخصم (للوحدة)" FontSize="13" Foreground="#546E7A"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ReturnDetail.PriceAfterDiscount, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="12" Foreground="#0D47A1"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Subtotal before tax -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="الإجمالي قبل الضريبة" FontSize="13" Foreground="#546E7A"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ReturnDetail.PriceAfterDiscount, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text=" × " FontSize="12" Foreground="#78909C"/>
                                            <TextBlock Text="{Binding ReturnDetail.Quantity}" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text=" = " FontSize="12" Foreground="#78909C"/>
                                            <TextBlock Text="{Binding ReturnDetail.SubtotalBeforeTax, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="12" Foreground="#0D47A1"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Tax -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="الضريبة" FontSize="13" Foreground="#E65100"/>
                                            <TextBlock Text="{Binding ReturnDetail.TaxRate, StringFormat='{} ({0}%)'}" FontSize="11" Foreground="#FF8A65" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ReturnDetail.TaxAmount, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CurrencySymbol}" FontSize="12" Foreground="#E65100"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Grand Total with divider -->
                                    <Border BorderThickness="0,1.5,0,0" BorderBrush="#1565C0" Padding="0,8,0,0" Margin="0,4,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="إجمالي مبلغ الاسترداد" FontSize="15" FontWeight="Bold" Foreground="#0D47A1"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding ReturnDetail.TotalRefundAmount, StringFormat='{}{0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding CurrencySymbol}" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ===== Reason & User ===== -->
                            <Border Background="#F5F5F5" CornerRadius="8" Padding="16" Margin="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Reason -->
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="سبب المرتجع" FontSize="11" Foreground="#90A4AE" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ReturnDetail.Reason}" FontSize="13" Foreground="#37474F"
                                                   TextWrapping="Wrap" MaxHeight="60"/>
                                    </StackPanel>

                                    <!-- User who processed -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="بواسطة" FontSize="11" Foreground="#90A4AE" Margin="0,0,0,4"/>
                                        <Border Background="#E8EAF6" CornerRadius="4" Padding="10,4">
                                            <TextBlock Text="{Binding ReturnDetail.UserName}" FontSize="13" FontWeight="SemiBold" Foreground="#3949AB"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Detail Dialog Footer -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Button Command="{Binding CloseDetailDialogCommand}"
                                Style="{StaticResource PrimaryButton}" Height="42" Padding="32,0"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="إغلاق" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Border>

    </Grid>
</Page>

<Window x:Class="AutoPartsShop.UI.Views.LicenseActivationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفعيل الترخيص" Width="560" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E88E5" Padding="20,16">
            <StackPanel>
                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="تفعيل نظام قطع غيار السيارات" FontSize="18" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="يرجى إدخال مفتاح الترخيص أو استيراد ملف الترخيص للاستمرار"
                           FontSize="12" Foreground="#BBDEFB" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Current License Status Card -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="حالة الترخيص الحالية" FontSize="14" FontWeight="Bold"
                                   Foreground="#333" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="الحالة:" FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="{Binding LicenseStatusText}" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrial}" Value="True">
                                                <Setter Property="Foreground" Value="#FF9800"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,8" Visibility="{Binding HasLicense, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="العميل:" FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="{Binding CustomerNameText}" Foreground="#333"/>
                        </Grid>

                        <Grid Margin="0,0,0,8" Visibility="{Binding HasLicense, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="نوع الترخيص:" FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="{Binding LicenseTypeText}" Foreground="#333"/>
                        </Grid>

                        <Grid Margin="0,0,0,8" Visibility="{Binding HasLicense, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="تاريخ الانتهاء:" FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="{Binding ExpirationText}" Foreground="#333"/>
                        </Grid>

                        <Grid Visibility="{Binding HasLicense, Converter={StaticResource BoolToVisConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="المتبقي:" FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="{Binding DaysRemainingText}" Foreground="#333"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Hardware Fingerprint Card -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE912;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#1E88E5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="بصمة الجهاز (Hardware ID)" FontSize="14" FontWeight="Bold"
                                   Foreground="#333" Margin="0,0,0,6"/>
                        <TextBlock Text="أرسل هذه البصمة لمزود البرنامج للحصول على مفتاح الترخيص"
                                   FontSize="11" Foreground="#999" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding HardwareFingerprint, Mode=OneWay}" IsReadOnly="True"
                                     FontSize="11" FontFamily="Consolas" Padding="8,6"
                                     Background="#F5F5F5" BorderBrush="#DDD" FlowDirection="LeftToRight"
                                     TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Command="{Binding CopyFingerprintCommand}"
                                    Padding="12,6" Margin="8,0,0,0" Background="#1E88E5"
                                    Foreground="White" BorderThickness="0" Cursor="Hand"
                                    ToolTip="نسخ البصمة"
                                    AutomationProperties.Name="Copy fingerprint">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Activation Method 1: License Key -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#1E88E5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="الطريقة 1: إدخال مفتاح الترخيص" FontSize="14" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="الصق مفتاح الترخيص هنا (يبدأ بـ AP1-)"
                                   FontSize="11" Foreground="#999" Margin="0,0,0,8"/>

                        <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" FontFamily="Consolas" Padding="10,8"
                                 FlowDirection="LeftToRight" TextWrapping="Wrap"
                                 AcceptsReturn="False" MaxLength="500"
                                 BorderBrush="#1E88E5" BorderThickness="1"
                                 AutomationProperties.Name="License key input"/>

                        <Button Command="{Binding ActivateCommand}"
                                Margin="0,10,0,0" Padding="16,8"
                                Background="#1E88E5" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                AutomationProperties.Name="Activate license key">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="تفعيل المفتاح" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Activation Method 2: Import License File -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="الطريقة 2: استيراد ملف الترخيص (.lic)" FontSize="14" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="استورد ملف الترخيص الذي حصلت عليه من مزود البرنامج"
                                   FontSize="11" Foreground="#999" Margin="0,0,0,8"/>

                        <Button Command="{Binding ImportLicenseFileCommand}"
                                Padding="16,8"
                                Background="#4CAF50" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                AutomationProperties.Name="Import license file">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="استيراد ملف الترخيص" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Trial Section -->
                <Border Background="#FFF3E0" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#FFE0B2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#E65100" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="فترة التجربة المجانية" FontSize="13" FontWeight="Bold"
                                   Foreground="#E65100" Margin="0,0,0,4"/>
                        <TextBlock Text="يمكنك تجربة النظام لمدة 14 يوماً مجاناً. بعد ذلك يجب تفعيل الترخيص."
                                   FontSize="11" Foreground="#BF360C" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <Button Command="{Binding StartTrialCommand}" Padding="12,8"
                                Background="#FF9800" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                Visibility="{Binding IsTrial, Converter={StaticResource BoolToVisConverter}}"
                                AutomationProperties.Name="Start trial period">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="بدء فترة التجربة (14 يوم)"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Deactivate Button -->
                <Button Command="{Binding DeactivateCommand}" Padding="12,6"
                        Background="Transparent" Foreground="#E53935"
                        BorderBrush="#E53935" BorderThickness="1" Cursor="Hand"
                        HorizontalAlignment="Left" FontSize="12"
                        Visibility="{Binding HasLicense, Converter={StaticResource BoolToVisConverter}}"
                        AutomationProperties.Name="Deactivate license">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء الترخيص"/>
                    </StackPanel>
                </Button>

                <!-- Status Message -->
                <Border Padding="12,8" CornerRadius="6" Margin="0,12,0,0"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#C62828"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- System Owner Info Card -->
                <Border Background="#E3F2FD" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                        BorderBrush="#90CAF9" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#1565C0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="معلومات مالك النظام" FontSize="14" FontWeight="Bold"
                                       Foreground="#1565C0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="الاسم:" FontWeight="SemiBold" Foreground="#1565C0"/>
                            <TextBlock Grid.Column="1" Text=" على حسن محمد" Foreground="#0D47A1" FontWeight="Bold" FontSize="13"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="الهاتف:" FontWeight="SemiBold" Foreground="#1565C0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" FlowDirection="LeftToRight">
                                <TextBlock Text="+967 775 232 319" Foreground="#0D47A1" FontSize="12" Margin="0,0,0,2"/>
                                <TextBlock Text="+967 777 909 692" Foreground="#0D47A1" FontSize="12" Margin="0,0,0,2"/>
                                <TextBlock Text="+967 733 551 010" Foreground="#0D47A1" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="للحصول على مفتاح الترخيص أو تجديده، يرجى التواصل مع مالك النظام"
                                   FontSize="11" Foreground="#1976D2" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FAFAFA" Padding="16,12"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding CloseCommand}" Padding="24,8"
                        Background="#757575" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"
                        AutomationProperties.Name="Close">
                    <TextBlock Text="إغلاق"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

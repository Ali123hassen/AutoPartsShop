<Page x:Class="AutoPartsShop.UI.Views.SpareParts.SparePartListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AutoPartsShop.UI.ViewModels"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <converters:DecimalToStringConverter x:Key="DecimalToString"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="إدارة الأصناف (قطع الغيار)" Style="{StaticResource PageTitleStyle}"/>

        <!-- Search & Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                <!-- Search TextBox -->
                <TextBox x:Name="SearchBox"
                         Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="بحث بالاسم أو رقم القطعة أو الباركود"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchBox_KeyDown"/>

                <!-- Category Filter -->
                <ComboBox Width="180"
                          ItemsSource="{Binding Categories}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedCategoryId}"
                          Margin="0,0,12,0"/>

                <!-- Search Button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Content="بحث"
                        Command="{Binding SearchCommand}"
                        Margin="0,0,12,0"
                        MinWidth="80"/>

                <!-- Show Inactive Toggle -->
                <CheckBox Content="عرض غير النشطة"
                          IsChecked="{Binding ShowInactive}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          FontSize="12"
                          Cursor="Hand"/>

                <!-- Add New -->
                <Button Style="{StaticResource SuccessButton}"
                        Content="+ إضافة صنف جديد"
                        Command="{Binding AddNewCommand}"
                        MinWidth="140"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <DataGrid ItemsSource="{Binding SpareParts}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      SelectedItem="{Binding SelectedSparePart}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم القطعة" Binding="{Binding PartNumber}" Width="100"/>
                    <DataGridTextColumn Header="الباركود" Binding="{Binding Barcode}" Width="120"/>
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="التصنيف" Binding="{Binding CategoryName}" Width="100"/>
                    <DataGridTextColumn Header="الشركة المصنعة" Binding="{Binding Manufacturer}" Width="100"/>
                    <DataGridTextColumn Header="السيارة المتوافقة" Binding="{Binding CompatibleCar}" Width="110"/>
                    <DataGridTextColumn Header="الموديل" Binding="{Binding CarModel}" Width="80"/>
                    <DataGridTextColumn Header="بلد المنشأ" Binding="{Binding CountryOfOrigin}" Width="80"/>

                    <!-- الحالة -->
                    <DataGridTemplateColumn Header="الحالة" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                                            <Setter Property="Background" Value="#D4EDDA"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#F8D7DA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="نشط"/>
                                                <Setter Property="Foreground" Value="#155724"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="غير نشط"/>
                                                        <Setter Property="Foreground" Value="#721C24"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- إجراءات -->
                    <DataGridTemplateColumn Header="إجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="تعديل"
                                            AutomationProperties.Name="تعديل">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="حذف"
                                            AutomationProperties.Name="حذف">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center">
                    <Run Text="الصفحة "/><Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text=" من "/><Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlineButton}" Content="السابق"
                            Command="{Binding PreviousPageCommand}" Margin="0,0,8,0"
                            Height="32" MinWidth="70" FontSize="12"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="التالي"
                            Command="{Binding NextPageCommand}"
                            Height="32" MinWidth="70" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page x:Class="AutoPartsShop.UI.Views.Inventory.StockMovementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:AutoPartsShop.UI.Converters"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InvertBoolConverter x:Key="InvertBool"/>
        <converters:NullableNumericConverter x:Key="NullableNumeric"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->
        <TextBlock Grid.Row="0" Text="إدارة المخزون" Style="{StaticResource PageTitleStyle}"/>

        <!-- بطاقات الإحصائيات -->
        <Border Grid.Row="1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <!-- إجمالي القطع -->
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalPartsCount}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="إجمالي القطع" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- مخزون منخفض -->
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LowStockCount}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock Text="مخزون منخفض" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- نفذ المخزون -->
                <Border Style="{StaticResource StatCardStyle}" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="&#xE89A;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding OutOfStockCount}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock Text="نفذ المخزون" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- قيمة المخزون -->
                <Border Style="{StaticResource StatCardStyle}" MinWidth="180">
                    <StackPanel>
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalStockValue, StringFormat='{}{0:N0}'}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="{Binding StockValueLabel}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- المحتوى الرئيسي - تابات -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Style="{StaticResource ModernTabControl}">

                <!-- ============ تاب تعديل المخزون ============ -->
                <TabItem Style="{StaticResource ModernTabItem}" Header="تعديل المخزون">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- رسالة الحالة -->
                        <Border Grid.Row="0" Background="#FDEDEC" CornerRadius="4" Padding="12,8" Margin="0,0,0,16"
                                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- نموذج تعديل المخزون -->
                        <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- اختيار القطعة -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="القطعة *" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding SpareParts}"
                                              DisplayMemberPath="Name"
                                              SelectedItem="{Binding SelectedSparePart}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"/>
                                </StackPanel>

                                <!-- نوع الحركة -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="نوع الحركة *" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding MovementTypes}"
                                              SelectedItem="{Binding MovementType}"/>
                                </StackPanel>

                                <!-- الكمية -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="الكمية *" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox Text="{Binding AddQuantity, Converter={StaticResource NullableNumeric}, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- زر التنفيذ -->
                                <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                    <Button Style="{StaticResource SuccessButton}"
                                            Command="{Binding AddStockCommand}"
                                            MinWidth="120">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="تنفيذ"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ملاحظات + معلومات القطعة المختارة -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ملاحظات -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ملاحظات" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding AddNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>

                            <!-- معلومات القطعة المختارة -->
                            <Border Grid.Column="2" Background="#EBF5FB" CornerRadius="6" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="معلومات القطعة" FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="الاسم: " FontWeight="SemiBold" FontSize="12" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSparePart.Name}" FontSize="12" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="الرقم: " FontWeight="SemiBold" FontSize="12" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedSparePart.PartNumber}" FontSize="12" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="المخزون: " FontWeight="SemiBold" FontSize="12" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSparePart.CurrentStock}" FontSize="12" Margin="0,0,0,4"
                                                   FontWeight="Bold"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="الحد الأدنى: " FontWeight="SemiBold" FontSize="12" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedSparePart.MinStockLevel}" FontSize="12" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="سعر الشراء: " FontWeight="SemiBold" FontSize="12" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedSparePart.PurchasePrice, StringFormat='{}{0:N2}'}" FontSize="12" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>

                                    <!-- رسالة عند عدم اختيار قطعة -->
                                    <TextBlock Text="اختر قطعة لتعديل مخزونها"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,16,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSparePart}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ============ تاب حركات المخزون ============ -->
                <TabItem Style="{StaticResource ModernTabItem}" Header="حركات المخزون">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- شريط البحث -->
                        <Border Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Width="300" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="بحث بالاسم أو الملاحظات" Margin="0,0,12,0"
                                         VerticalContentAlignment="Center"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="بحث"
                                        Command="{Binding SearchMovementsCommand}" MinWidth="80" Margin="0,0,12,0"/>
                                <Button Style="{StaticResource OutlineButton}" Content="تحديث"
                                        Command="{Binding RefreshCommand}" MinWidth="80"/>
                            </StackPanel>
                        </Border>

                        <!-- جدول الحركات -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Movements}"
                                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="130"/>
                                <DataGridTextColumn Header="القطعة" Binding="{Binding SparePartName}" Width="*"/>
                                <DataGridTemplateColumn Header="نوع الحركة" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D4EDDA"/>
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                        <Setter Property="Padding" Value="8,2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MovementType}" Value="Out">
                                                                <Setter Property="Background" Value="#F8D7DA"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MovementType}" Value="Adjustment">
                                                                <Setter Property="Background" Value="#FFF3CD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MovementType}" Value="Return">
                                                                <Setter Property="Background" Value="#D1ECF1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="إدخال"/>
                                                            <Setter Property="Foreground" Value="#155724"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="Out">
                                                                    <Setter Property="Text" Value="إخراج"/>
                                                                    <Setter Property="Foreground" Value="#721C24"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="Adjustment">
                                                                    <Setter Property="Text" Value="تسوية"/>
                                                                    <Setter Property="Foreground" Value="#856404"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="Return">
                                                                    <Setter Property="Text" Value="مرتجع"/>
                                                                    <Setter Property="Foreground" Value="#0C5460"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="70"/>
                                <DataGridTextColumn Header="قبل" Binding="{Binding PreviousStock}" Width="70"/>
                                <DataGridTextColumn Header="بعد" Binding="{Binding NewStock}" Width="70"/>
                                <DataGridTextColumn Header="المرجع" Binding="{Binding ReferenceType}" Width="110"/>
                                <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="150"/>
                                <DataGridTextColumn Header="بواسطة" Binding="{Binding UserName}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ============ تاب تنبيهات المخزون ============ -->
                <TabItem Style="{StaticResource ModernTabItem}" Header="تنبيهات المخزون">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- عدد التنبيهات -->
                        <Border Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="عدد القطع منخفضة المخزون: "
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LowStockItems.Count}" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- جدول القطع منخفضة المخزون -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding LowStockItems}"
                                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم القطعة" Binding="{Binding PartNumber}" Width="110"/>
                                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="التصنيف" Binding="{Binding CategoryName}" Width="110"/>
                                <DataGridTemplateColumn Header="المخزون" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CurrentStock}" FontWeight="Bold"
                                                       Foreground="#E74C3C" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinStockLevel}" Width="80"/>
                                <DataGridTextColumn Header="النقص" Width="80">
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="MinStockLevel"/>
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="سعر الشراء" Binding="{Binding PurchasePrice, StringFormat='{}{0:N2}'}" Width="90"/>
                                <DataGridTextColumn Header="المورد" Binding="{Binding SupplierName}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>
